# Enclave agent config — copy to .env and edit.
AGENT_ID=my-agent

# Brain: claude (subscription/token) | api (OpenRouter/DeepSeek/…) | local (Ollama)
BRAIN=claude
MODEL=claude-sonnet-4-6

# Loop: daemon = event-driven (wakes on chat/inbox); tick = fixed interval
RUNTIME_MODE=daemon
INTERVAL_SECONDS=86400

# Permission mode: dangerous (guard hook is the structural net) | acceptEdits | allowlist
PERMISSION=dangerous

# Working folder: the HOST directory the agent operates on and saves work into (mounted rw at /work).
# Leave blank to default to ./home/work (inside the vault). Point it at a real project tree to make
# that tree the agent's working folder. Index it for fresh recall — see docs/WORK-DIR.md.
# WORK_DIR=/abs/path/to/your/project

# Web chat bind (host:port). Keep on 127.0.0.1 — the agent has no inbound ports of its own.
WEB_CHAT_BIND=127.0.0.1:8888
# WEB_CHAT_TOKEN=               # optional ?token= gate for the web UI

# Prebuilt images (optional): point these at a registry, then `enclave run --pull` to skip local builds.
# ENCLAVE_AGENT_IMAGE=ghcr.io/<owner>/enclave-agent:latest
# ENCLAVE_CHAT_IMAGE=ghcr.io/<owner>/enclave-chat:latest

# Server-side voice (optional privacy opt-in): point these at a compatible service and the chat uses
# it instead of the browser's Web Speech API. Contracts in docs/VOICE-BACKEND.md.
# TRANSCRIBE_URL=http://host.docker.internal:18185/transcribe   # POST {audio_base64,mime} -> {text}
# TTS_URL=http://host.docker.internal:18186/tts                 # POST {text,voice} -> audio bytes
# TTS_VOICE=

# --- credentials live in ./secrets/ (gitignored), NOT here ---
# secrets/anthropic.env   -> CLAUDE_CODE_OAUTH_TOKEN=...   (BRAIN=claude; required)
# secrets/openrouter.env  -> OPENROUTER_API_KEY=...        (BRAIN=api)

# Optional Telegram interface (docker compose --profile telegram up -d):
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
