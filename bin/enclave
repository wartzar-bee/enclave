#!/usr/bin/env python3
"""
enclave — CLI for the Enclave agent runtime.

Commands:
  enclave new <name> [--dir P]     Scaffold a NEW deployment in its own folder (names the folder + agent + free port; --image-only = lightweight shared-image)
  enclave init                     Interactive wizard: configure this deployment (home/, secrets/, .env)
  enclave brain <mode>             Switch brain in place (claude|api|local|optimize) + recreate the container (keeps memory)
  enclave fleet [list|open <id>]   Fleet control plane (CLI): list ALL deployments (status/brain/model/port); also up/down/restart/logs/send <id>
  enclave console [--port N]       Web fleet console: rail of agents + detail/chat/logs + directives, all deployments in one panel
  enclave update [--from D|--pull] Update this deployment's runtime to latest + rebuild (keeps home/secrets/.env/compose)
  enclave run                      Build + start the agent, then open the chat in your browser
  enclave app                      macOS: install an /Applications launcher (start agent + open chat by icon)
  enclave send <msg>               Send a message to the agent's inbox
  enclave logs                     Tail the agent's runner log
  enclave status                   Show agent health and recent activity
  enclave stop                     Stop the agent containers
  enclave chat                     Interactive terminal chat (reads the reply file)
  enclave snapshot ["msg"]         Commit the memory vault (scan-gated, fail-closed). Auto-runs each tick.
  enclave vault-encrypt            Encrypt the brain to an at-rest archive (key in secrets/, never committed)
  enclave vault-decrypt <blob>     Restore the brain from an encrypted archive
  enclave publish --registry R     Maintainer: build + push images to a registry (teammates `run --pull`)

The wizard + run/stop/etc. all operate on the Enclave repo this script lives in
(the clone IS the deployment, like a configured ps-ops checkout). `init` populates
./home (the agent's mounted /agent), ./secrets (read-only creds), and ./.env, and
makes ./home its own scan-gated git vault so memory survives a machine wipe.

Operating a deployment elsewhere (a fleet of shared-image agents from ONE checkout):
  --dir PATH       any lifecycle/init command operates on the deployment at PATH (its home/secrets/.env/
                   compose), while templates + runtime come from THIS checkout. So one canonical clone
                   creates + runs many agents; rebuild the image once → every deployment inherits.
  --image-only     (new/init) LIGHTWEIGHT deployment: only .env/docker-compose.yml/home/secrets,
                   referencing the shared prebuilt image (ENCLAVE_AGENT_IMAGE/ENCLAVE_CHAT_IMAGE).
  --allow-git      (new/init) let THIS agent `git push` (default: agents can't). Sets up a credential
                   helper so it authenticates via secrets/git.env (GIT_USERNAME/GIT_TOKEN) WITHOUT ever
                   reading the raw token. ⚠ trust boundary — only for an agent you trust to push.
  --spec FILE      (new/init) create from a declarative agent spec (.yaml/.yml/.json): fields
                   name/brain/model/template/work_dir/qmd/codegraph map to flags; mission/kpi append to
                   CLAUDE.md; secrets[] make scoped placeholder env files; interval_seconds + guardrails
                   set agent.env. The reproducible way for a manager agent to define + graduate one.

Flags for non-interactive init (CI / scripted):
  --name N --brain claude|api|local|optimize --model M --template T
                   (optimize = start on Claude, shift to the cheapest reachable policy.json pool as the cap fills)
  --cred TOKEN     the model credential (Claude OAuth / API key) — what the wizard prompts for
  --codegraph PATH code memory over a repo folder — `run` starts it as this agent's OWN compose service,
                   PRIVATE to the agent's network (no host port, no cross-agent reach); reached at
                   http://codegraph:18184/mcp. Twin of qmd.
  --qmd URL        a knowledge-search qmd MCP gateway URL (blank = none)
  --work-dir PATH  the host project tree the agent works in (mounted rw at /work; blank = home/work)
  --bind 127.0.0.1:8888  --port 8888  --token TOK (optional web-UI ?token= gate)  --yes  --force
  --allow-unknown-model   accept a Claude model id not in the known-good set (e.g. a newer release)
Flags for run:
  --no-open   don't auto-open the browser
  --no-build  skip the image build (use existing local images)
  --pull      pull prebuilt images from the registry instead of building (see ENCLAVE_*_IMAGE in .env)
"""
import sys, os, re, json, time, pathlib, subprocess, shutil, getpass, urllib.request

HERE = pathlib.Path(__file__).resolve().parent
REPO = HERE.parent  # bin/ -> repo root
# DEPLOY = the deployment being operated on (its home/secrets/.env/docker-compose.yml live here).
# Defaults to REPO (the clone IS the deployment). `--dir <path>` points lifecycle + init commands at a
# LIGHTWEIGHT deployment elsewhere, while SOURCE assets (templates/, platform/, Dockerfiles) still come
# from REPO. This split is what lets ONE canonical checkout create and operate many shared-image agents
# under a fleet root — so a runtime improvement (rebuild the image once) reaches every deployment.
DEPLOY = REPO
# (codegraph runs as the agent's own compose service on its PRIVATE network — service name `codegraph`,
#  port 18184 inside the project, never host-published. No shared host port → no cross-agent reach.)

# Brain presets: default model + the secret file/key the runtime reads from ./secrets/.
BRAINS = {
    "claude": {"model": "claude-sonnet-4-6", "secret_file": "anthropic.env",
               "secret_key": "CLAUDE_CODE_OAUTH_TOKEN",
               "cred_prompt": "Claude Code OAuth token (from `claude setup-token`)"},
    "api":    {"model": "deepseek/deepseek-chat", "secret_file": "openrouter.env",
               "secret_key": "OPENROUTER_API_KEY",
               "cred_prompt": "OpenRouter API key (sk-or-...)"},
    "local":  {"model": "qwen2.5:7b", "secret_file": None, "secret_key": None,
               "cred_prompt": None},
    # optimize: start on Claude (subscription token below), shift to the cheapest reachable pool in
    # policy.json as the cap fills. The pool wizard (init) writes policy.json + per-pool secret envs.
    "optimize": {"model": "claude-opus-4-8", "secret_file": "anthropic.env",
                 "secret_key": "CLAUDE_CODE_OAUTH_TOKEN",
                 "cred_prompt": "Claude Code OAuth token (from `claude setup-token`) — optimize starts on Claude"},
}

# BRAIN=api providers: a `provider` spec field expands to the endpoint base + the NAME of the key var the
# runtime resolves from secrets/ + the secret-file that key lives in. Add a row to support a new provider;
# "custom" means base+key_env are given explicitly. (Any OpenAI-compatible endpoint works.)
PROVIDERS = {
    "nvidia":     {"base": "https://integrate.api.nvidia.com/v1", "key_env": "NVIDIA_API_KEY",     "secret": "nvidia.env"},
    "openrouter": {"base": "https://openrouter.ai/api/v1",        "key_env": "OPENROUTER_API_KEY", "secret": "openrouter.env"},
}

# Known-good Claude model ids (the chat picker's allowlist). A typo here = a silently dead chat
# ("couldn't generate a reply"), so init/brain reject an unknown one unless --allow-unknown-model.
KNOWN_CLAUDE_MODELS = {"claude-opus-4-8", "claude-sonnet-4-6", "claude-haiku-4-5"}

def _check_claude_model(model, allow):
    """For brains that run on Claude, reject a model id that isn't known-good (catches typos at config
    time). Forward-compat escape hatch: --allow-unknown-model. No-op for non-Claude models."""
    if allow or not (model or "").startswith("claude-") or model in KNOWN_CLAUDE_MODELS:
        return
    sys.exit(f"Unknown Claude model '{model}'. Valid: {', '.join(sorted(KNOWN_CLAUDE_MODELS))}.\n"
             f"  (this is the typo that silently kills the chat — pass --allow-unknown-model to "
             f"use a model not in this list, e.g. one released after this build.)")


# ── small interactive helpers ────────────────────────────────────────────────
def _interactive():
    return sys.stdin.isatty() and sys.stdout.isatty()

def _ask(label, default=None, choices=None, yes=False):
    if choices:
        label = f"{label} [{'/'.join(choices)}]"
    if default not in (None, ""):          # show a default in (parens); skip for None/empty (no stray "()")
        label = f"{label} ({default})"
    if yes or not _interactive():
        return default
    while True:
        try:
            ans = input(f"  {label}: ").strip()
        except (EOFError, KeyboardInterrupt):
            print("\nAborted."); sys.exit(1)
        if not ans:
            return default
        if choices and ans not in choices:
            print(f"    please choose one of: {', '.join(choices)}"); continue
        return ans

def _ask_secret(label, yes=False):
    if yes or not _interactive():
        return ""
    try:
        return getpass.getpass(f"  {label}\n  (paste, or press Enter to skip and add it later): ").strip()
    except (EOFError, KeyboardInterrupt):
        print(); return ""

def _optimize_pool_wizard(yes):
    """Build the BRAIN=optimize pool config — any OpenAI-compatible provider (xAI/OpenAI/Groq/OpenRouter/
    local mlx/ollama). Returns (policy_dict, {secret_filename: 'KEY=val\\n'}). --yes / non-interactive ships
    the documented baked defaults (operator edits home/policy.json + adds secrets later)."""
    try:
        base = json.loads((REPO / "platform" / "agentd" / "policy.json").read_text())
    except Exception:
        base = {"cap": {"soft_pct": 70, "hard_pct": 90}, "pools": {}}
    if yes or not _interactive():
        return base, {}
    print("\n  BRAIN=optimize runs Claude first (free at the margin) and shifts to the CHEAPEST reachable")
    print("  pool as the 5h/7d cap fills. Add ANY OpenAI-compatible provider (xAI, OpenAI, Groq, OpenRouter,")
    print("  a local mlx/ollama server). You can edit home/policy.json anytime to add/remove pools.\n")
    pools, secret_envs = {}, {}
    lbase = _ask("Local server base URL (e.g. http://host.docker.internal:8081/v1; blank = no local)",
                 default="", yes=yes).strip()
    if lbase:
        lmodel = _ask("  Local model tag the server serves (blank = its default)", default="", yes=yes).strip()
        pools["local"] = {"base_url": lbase, "api_key_env": "LOCAL_LLM_KEY", "api_key_default": "x",
                          "model": lmodel, "cost": "free", "local": True}
    print("\n  Remote pools — press Enter at the name to finish:")
    while True:
        nm = _ask("  Pool name (e.g. cheap, top, xai)", default="", yes=yes).strip()
        if not nm:
            break
        nm = nm.replace(" ", "-")
        base_url = _ask(f"    {nm} base URL (e.g. https://api.x.ai/v1, https://openrouter.ai/api/v1)",
                        default="", yes=yes).strip()
        if not base_url:
            print("    (no base URL — skipped)"); continue
        model = _ask(f"    {nm} model id (e.g. grok-4, google/gemini-2.5-flash, anthropic/claude-sonnet-4.6)",
                     default="", yes=yes).strip()
        key_env = _ask(f"    {nm} API-key ENV var name", default=f"{nm.upper().replace('-', '_')}_API_KEY",
                       yes=yes).strip()
        cost = _ask(f"    {nm} cost tier", default="high", choices=["free", "low", "high"], yes=yes)
        keyval = _ask_secret(f"    {nm} API key")
        pools[nm] = {"base_url": base_url, "api_key_env": key_env, "model": model,
                     "cost": cost, "local": False}
        secret_envs[f"{nm}.env"] = (f"{key_env}={keyval}\n" if keyval
                                    else f"# add the key, no quotes:\n{key_env}=\n")
    return {"cap": base.get("cap", {"soft_pct": 70, "hard_pct": 90}), "pools": pools,
            "_doc": base.get("_doc", ""), "_routing_doc": base.get("_routing_doc", "")}, secret_envs


def _flag(args, name, default=None):
    if name in args:
        i = args.index(name)
        if i + 1 < len(args):
            return args[i + 1]
    return default

def _has(args, name):
    return name in args

def _free_port(start=8888, host="127.0.0.1"):
    """First free TCP port at/after `start` — so multiple deployments don't collide on 8888."""
    import socket
    for p in range(start, start + 200):
        with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
            s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
            try:
                s.bind((host, p)); return p
            except OSError:
                continue
    return start


# ── init wizard ──────────────────────────────────────────────────────────────
def _templates():
    tdir = REPO / "templates"
    return sorted(p.name for p in tdir.iterdir() if p.is_dir()) if tdir.exists() else []

def _write(path, text, mode=None):
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(text)
    if mode is not None:
        os.chmod(path, mode)

# Vault persistence + encryption delegate to the ONE canonical implementation (single source of
# truth for the secret-scan patterns), shared with runtime.sh's post-tick auto-snapshot.
VAULT_SCRIPT = REPO / "platform" / "agentd" / "vault_snapshot.py"

def _vault(home, sub, *extra):
    return subprocess.run([sys.executable, str(VAULT_SCRIPT), sub, str(home), *extra])

def _init_vault_git(home):
    """Make home/ a scan-gated git vault (idempotent). Returns the script's stdout word."""
    r = subprocess.run([sys.executable, str(VAULT_SCRIPT), "init", str(home)], capture_output=True, text=True)
    return (r.stdout or "").replace("vault:", "").strip() or None

def cmd_snapshot(args):
    """Durably save memory (survives a machine wipe) — SCAN-GATED, fail-closed. The agent can't git
    (guard-blocked); the runtime/operator snapshots. Usage: enclave snapshot ["message"]"""
    home = DEPLOY / "home"
    if not home.exists():
        sys.exit("no home/ — run `enclave init` first")
    msg = " ".join(a for a in args if not a.startswith("--"))
    r = _vault(home, "snapshot", *(["--msg", msg] if msg else []))
    sys.exit(1 if r.returncode == 3 else 0)   # 3 = blocked by the secret gate (already reported)

def cmd_vault_encrypt(args):
    """Encrypt the brain to an off-machine-safe archive (CIPHERTEXT at rest — covers a scanner miss).
    Key stays in secrets/vault.key (gitignored). Usage: enclave vault-encrypt [--out blob]"""
    home = DEPLOY / "home"
    if not home.exists():
        sys.exit("no home/ — run `enclave init` first")
    out = _flag(args, "--out")
    _vault(home, "encrypt", *(["--out", out] if out else []))

def cmd_vault_decrypt(args):
    """Restore the brain from an encrypted archive. Usage: enclave vault-decrypt <blob.enc>"""
    home = DEPLOY / "home"
    blob = next((a for a in args if not a.startswith("--")), None)
    if not blob:
        sys.exit("Usage: enclave vault-decrypt <blob.enc>")
    _vault(home, "decrypt", "--in", blob)

# ── agent spec (the one declarative way to define an agent) ────────────────────
# A spec (.yaml/.yml/.json) is the canonical agent definition: simple fields map to init flags; richer
# fields (mission/kpi/secrets/interval_seconds/guardrails) are applied after scaffolding. A manager
# agent (e.g. a fleet master) writes a spec to graduate a sub-agent into its own deployment reproducibly.
SPEC_TO_FLAG = {
    "name": "--name", "brain": "--brain", "model": "--model", "template": "--template",
    "role": "--template", "work_dir": "--work-dir", "bind": "--bind", "port": "--port",
    "token": "--token", "qmd": "--qmd", "codegraph": "--codegraph", "cred": "--cred",
}

def _load_spec(path):
    p = pathlib.Path(path).expanduser()
    if not p.exists():
        sys.exit(f"--spec file not found: {p}")
    if p.suffix in (".yaml", ".yml"):
        try:
            import yaml
        except ImportError:
            sys.exit("--spec is YAML but PyYAML isn't installed (`pip install pyyaml`), or use a .json spec")
        data = yaml.safe_load(p.read_text())
    else:
        data = json.loads(p.read_text())
    if not isinstance(data, dict):
        sys.exit("--spec must be a mapping (name/brain/model/template/mission/…)")
    return data

def _spec_args(spec):
    """Spec simple fields → init-flag tokens, appended AFTER the user's args so an explicit CLI flag
    still wins (_flag returns the first match)."""
    out = []
    for key, flag in SPEC_TO_FLAG.items():
        if spec.get(key) not in (None, ""):
            out += [flag, str(spec[key])]
    return out

def _clone_source_home(agent_id):
    """Resolve an existing agent's home/ by id under ENCLAVE_STACKS_ROOTS (the fleet roots the console
    discovers agents from). Returns a Path or None."""
    roots = (os.environ.get("ENCLAVE_STACKS_ROOTS") or str(REPO.parent)).split(":")
    for r in roots:
        h = pathlib.Path(r).expanduser() / agent_id / "home"
        if h.is_dir():
            return h
    return None

def _clone_brain(agent_id, home, include_work):
    """Seed `home` from an existing agent's BRAIN: copy its knowledge dirs (skills/knowledge/memory/
    reference/docs) + append its CLAUDE.md `## Mission` block. NEVER copies state/logs/secrets (runtime
    state starts fresh). include_work also copies work/ (heavy — may be a separate git tree)."""
    src = _clone_source_home(agent_id)
    if not src:
        print(f"  (clone_from: source agent '{agent_id}' not found under ENCLAVE_STACKS_ROOTS — skipped)")
        return
    dirs = ["skills", "knowledge", "memory", "reference", "docs"] + (["work"] if include_work else [])
    copied = []
    for d in dirs:
        s = src / d
        if s.is_dir():
            shutil.copytree(s, home / d, dirs_exist_ok=True,
                            ignore=shutil.ignore_patterns("__pycache__", "*.pyc", ".git"))
            copied.append(d)
    # carry the source's Mission block into the clone's CLAUDE.md (the model + endpoint differ, the job doesn't)
    try:
        srctxt = (src / "CLAUDE.md").read_text()
        i = srctxt.find("## Mission")
        if i != -1:
            cl = home / "CLAUDE.md"
            block = "\n\n" + srctxt[i:].strip() + "\n"
            if cl.exists() and "## Mission" not in cl.read_text():
                cl.write_text(cl.read_text().rstrip() + block)
    except OSError:
        pass
    print(f"  cloned BRAIN from '{agent_id}': {', '.join(copied) or '(no brain dirs found)'}")

def _apply_spec_extras(spec, home, secrets, envf):
    """Apply the spec fields that aren't plain init flags to the freshly-scaffolded deployment."""
    mission = (spec.get("mission") or "").strip()
    kpi = (spec.get("kpi") or "").strip()
    if mission or kpi:
        cl = home / "CLAUDE.md"
        block = "\n\n## Mission\n" + (mission or "(none)") + (f"\n\n## KPI\n{kpi}" if kpi else "") + "\n"
        cl.write_text((cl.read_text() if cl.exists() else "") + block)
    iv = spec.get("interval_seconds")
    if iv:
        _set_env_kv(home / "agent.env", {"INTERVAL_SECONDS": str(iv)})
        _set_env_kv(envf, {"INTERVAL_SECONDS": str(iv)})

    # requires[]: the tools/bridges/skills this mission needs → REQUIRES for the deterministic startup
    # preflight (runtime.sh + preflight.py). Known probes: route, render, qmd, codegraph, image, deploy_key,
    # voice, gcloud. The agent's toolchain is FUNCTIONALLY verified before the first Opus turn; a broken
    # required capability escalates (and, with preflight_gate, defers the tick — no Opus burn).
    reqs = spec.get("requires")
    if reqs:
        req_str = ",".join(str(r).strip() for r in reqs) if isinstance(reqs, (list, tuple)) else str(reqs).strip()
        _set_env_kv(home / "agent.env", {"REQUIRES": req_str})
        if spec.get("preflight_gate"):
            _set_env_kv(home / "agent.env", {"PREFLIGHT_GATE": "1"})

    # BRAIN=api endpoint wiring (the no-Claude path): a `provider` shorthand (nvidia/openrouter) expands to
    # base + key-env; explicit brain_api_base / brain_api_key_env / escalation_* win. Written into agent.env
    # so runtime.sh's BRAIN=api block drives local_agent.py against that endpoint with no Claude in the loop.
    if (spec.get("brain") or "").strip().lower() == "api":
        prov = (spec.get("provider") or "").strip().lower()
        pinfo = PROVIDERS.get(prov, {})
        api_base = (spec.get("brain_api_base") or pinfo.get("base") or "").strip()
        key_env = (spec.get("brain_api_key_env") or pinfo.get("key_env") or "").strip()
        apienv = {}
        if api_base:
            apienv["BRAIN_API_BASE"] = api_base
        if key_env:
            apienv["BRAIN_API_KEY_ENV"] = key_env
        if spec.get("escalation_model"):
            apienv["ESCALATION_MODEL"] = str(spec["escalation_model"]).strip()
        if spec.get("escalation_base"):
            apienv["ESCALATION_BASE"] = str(spec["escalation_base"]).strip()
        if spec.get("api_budget_usd") not in (None, ""):
            apienv["API_BUDGET_USD"] = str(spec["api_budget_usd"]).strip()
        # Drop any Claude MODEL the template shipped — a BRAIN=api agent runs on BRAIN_MODEL, and a stray
        # MODEL=claude-… misleads the dashboard into showing a Claude model for a no-Claude agent.
        _set_env_kv(home / "agent.env", apienv, remove=("MODEL",))
        # Ensure the provider's secret-file placeholder exists so the operator knows where the key goes
        # (real value is staged by the spawn pipeline's secrets-staging, or pasted in later).
        sfile = pinfo.get("secret")
        if sfile and not (secrets / sfile).exists():
            secrets.mkdir(mode=0o700, parents=True, exist_ok=True)
            _write(secrets / sfile, f"# {sfile} — {key_env} for this agent's BRAIN=api endpoint, no quotes\n{key_env}=\n", mode=0o600)

    # clone_from: seed this agent's BRAIN from an existing deployment (a true twin that runs a different
    # model). Copies the knowledge dirs only — never state/logs/secrets — so memory/skills/reference carry
    # over while runtime state starts fresh. clone_work also copies the working tree (heavy; may be a repo).
    if spec.get("clone_from"):
        _clone_brain(str(spec["clone_from"]).strip(), home, bool(spec.get("clone_work")))

    names = []
    for s in (spec.get("secrets") or []):
        if isinstance(s, dict):
            fname = s.get("file") or (s.get("name", "") + ".env"); key = s.get("key", "")
        else:
            fname = str(s) if str(s).endswith(".env") else f"{s}.env"; key = ""
        if not fname or fname == ".env":
            continue
        names.append(fname)
        sp = secrets / fname
        if not sp.exists():
            _write(sp, (f"{key}=\n" if key else f"# {fname} — add this agent's credential(s), no quotes\n"), mode=0o600)
    if names:
        _write(home / "secrets.list", "\n".join(names) + "\n")
    gmap = {"cloud_readonly": ("GUARD_CLOUD_READONLY", "1")}
    upd = {gmap[g][0]: gmap[g][1] for g in (spec.get("guardrails") or []) if g in gmap}
    if upd:
        _set_env_kv(home / "agent.env", upd)

# Credential helper git uses internally so an allow_git agent can `git push` WITHOUT ever reading the
# raw token (the agent is guard-blocked from .secrets/git.env and from running this helper directly).
_GIT_HELPER = """#!/bin/sh
# Git credential helper (enclave allow_git). git invokes this internally to authenticate a push; the
# agent itself can't read .secrets/git.env or run this helper (guard.py SECRET_DENY) — so it can push
# but can't exfiltrate the token.
set -a
. /workspace/.secrets/git.env 2>/dev/null
set +a
echo "username=${GIT_USERNAME}"
echo "password=${GIT_TOKEN}"
"""

def _setup_git_push(home, secrets, name):
    """Wire `allow_git`: the agent may `git push`, authenticating via a credential helper that reads its
    OWN scoped secrets/git.env — without the agent ever seeing the raw token. Sets GUARD_ALLOW_GIT=1 +
    GIT_CONFIG_GLOBAL in agent.env, writes .gitconfig + the helper, and a git.env placeholder."""
    _set_env_kv(home / "agent.env", {"GUARD_ALLOW_GIT": "1", "GIT_CONFIG_GLOBAL": "/agent/.gitconfig"})
    _write(home / ".gitconfig",
           f"[user]\n\tname = {name}\n\temail = {name}@enclave.local\n"
           f"[credential]\n\thelper = \"!sh /agent/.gitcreds-helper.sh\"\n")
    _write(home / ".gitcreds-helper.sh", _GIT_HELPER)
    try:
        os.chmod(home / ".gitcreds-helper.sh", 0o755)
    except OSError:
        pass
    gpath = secrets / "git.env"
    if not gpath.exists():
        _write(gpath, "# git push credential for THIS agent (read only by the credential helper; the\n"
                      "# agent itself is guard-blocked from reading it). Fill both, no quotes.\n"
                      "GIT_USERNAME=\nGIT_TOKEN=\n", mode=0o600)

def cmd_init(args):
    # --spec <file>: load the declarative agent definition; its simple fields become init flags (an
    # explicit CLI flag still wins), and spec creation is non-interactive by default.
    spec = _load_spec(_flag(args, "--spec")) if _has(args, "--spec") else {}
    if spec:
        args = list(args) + _spec_args(spec) + ([] if _has(args, "--yes") else ["--yes"])
    yes = _has(args, "--yes")
    force = _has(args, "--force")
    # --image-only: a LIGHTWEIGHT deployment that references the shared prebuilt image (no per-agent
    # runtime/Dockerfiles), so a central image rebuild propagates to it. The deployment carries only
    # .env / docker-compose.yml / home / secrets.
    image_only = _has(args, "--image-only")
    # --allow-git / spec allow_git: let THIS agent `git push` (default agents can't). Sets up a
    # credential helper so it authenticates without ever reading the raw token. ⚠ trust boundary.
    allow_git = _has(args, "--allow-git") or bool(spec.get("allow_git"))
    home = DEPLOY / "home"
    secrets = DEPLOY / "secrets"
    envf = DEPLOY / ".env"

    populated = home.exists() and any(p.name != ".gitkeep" for p in home.iterdir())
    if populated and not force:
        sys.exit(f"./home is already populated ({home}). Re-run with --force to overwrite, "
                 f"or edit it directly. (secrets/ and .env are left untouched.)")

    print("\nEnclave setup — configure this deployment.\n")

    templates = _templates()
    tpl = _flag(args, "--template") or _ask("Template", default=("ops" if "ops" in templates else (templates[0] if templates else "ops")), choices=(templates or None), yes=yes)
    name = _flag(args, "--name") or _ask("Agent name", default="enclave-agent", yes=yes)
    brain = _flag(args, "--brain") or _ask("Brain", default="claude", choices=list(BRAINS), yes=yes)
    if brain not in BRAINS:
        sys.exit(f"Unknown brain '{brain}'. Choose: {', '.join(BRAINS)}")
    bspec = BRAINS[brain]
    model = _flag(args, "--model") or _ask("Model", default=bspec["model"], yes=yes)
    if brain in ("claude", "optimize"):     # optimize's top model runs on Claude too
        _check_claude_model(model, _has(args, "--allow-unknown-model"))
    bind = _flag(args, "--bind") or _ask("Web chat bind (host:port)", default=f"127.0.0.1:{_free_port()}", yes=yes)
    port = _flag(args, "--port") or (bind.split(":")[-1] if ":" in bind else "8888")
    token = _flag(args, "--token", "")  # web UI ?token= gate (optional)
    # Working folder: the host project tree the agent operates on + saves into (mounted rw at /work).
    # Blank → ./home/work (inside the vault). Point it at a real repo to make that the working folder.
    work_dir = _flag(args, "--work-dir") or _ask(
        "Working folder — ABSOLUTE host path the agent works in, e.g. /Users/you/Dev/myproject "
        "(blank = home/work, inside the vault)", default=None, yes=yes)

    # memory accelerators (opt-in) — ASK at install so .mcp.json reflects reality (no dead entries).
    #   codegraph = code memory over a repo folder, served as an HTTP bridge (twin of qmd).
    #   qmd       = a knowledge-search MCP gateway URL you already run (blank = none).
    cg_corpus = _flag(args, "--codegraph")
    if cg_corpus is None:
        cg_corpus = _ask("Code memory — absolute PATH to a repo folder to index with codegraph, "
                         "e.g. /Users/you/Dev/repos (blank = none)", default="", yes=yes)
    qmd_url = _flag(args, "--qmd")
    if qmd_url is None:
        qmd_url = _ask("Knowledge search — qmd MCP gateway URL, e.g. http://host.docker.internal:18182/mcp "
                       "(blank = none)", default="", yes=yes)
    cg_corpus = (cg_corpus or "").strip()
    qmd_url = (qmd_url or "").strip()

    # credential (paste now or later)
    cred = ""
    if bspec["secret_key"]:
        cred = _flag(args, "--cred") or _ask_secret(bspec["cred_prompt"], yes=yes)
        # Guided token for the Claude brain: a teammate may not have a token yet — offer to mint one.
        if not cred and not yes and _interactive() and brain in ("claude", "optimize"):
            if shutil.which("claude"):
                if _ask("No token entered. Run `claude setup-token` now to generate one?",
                        default="y", choices=["y", "n"], yes=yes) == "y":
                    print("  Launching `claude setup-token` — complete the browser login; it prints a token.\n")
                    subprocess.run(["claude", "setup-token"])
                    cred = _ask_secret("Paste the token it just printed")
            else:
                print("  (the `claude` CLI isn't on PATH — install it, run `claude setup-token`, then paste the token)")

    # BRAIN=optimize: gather the generic pool config (local + remote OpenAI-compatible providers).
    opt_policy, opt_secret_envs = ({}, {})
    if brain == "optimize":
        opt_policy, opt_secret_envs = _optimize_pool_wizard(yes)

    tdir = REPO / "templates" / tpl
    if not tdir.exists():
        sys.exit(f"Template '{tpl}' not found in {REPO/'templates'} (have: {', '.join(templates) or 'none'})")

    # 1) home/ from the template (CLAUDE.md, tick.txt, .mcp.json, .claude/settings.json)
    if home.exists() and force:
        # preserve runtime state if any; only replace the definition files
        pass
    home.mkdir(parents=True, exist_ok=True)
    for rel in ["CLAUDE.md", "tick.txt"]:    # .mcp.json is GENERATED below from the memory answers
        src = tdir / rel
        if src.exists():
            _write(home / rel, src.read_text().replace("{AGENT_NAME}", name))
    # 1a) ship the reusable operating methodology into EVERY agent + point its CLAUDE.md at it
    princ = REPO / "docs" / "AGENT-PRINCIPLES.md"
    if princ.exists():
        (home / "docs").mkdir(exist_ok=True)
        _write(home / "docs" / "AGENT-PRINCIPLES.md", princ.read_text())
        clf = home / "CLAUDE.md"
        if clf.exists() and "AGENT-PRINCIPLES" not in clf.read_text():
            clf.write_text(clf.read_text().rstrip() + "\n\n## Method (every tick)\n"
                "Follow `docs/AGENT-PRINCIPLES.md`: **plan → ground → review → build (one pass) → verify "
                "→ record.** Read code first + cite file:line; never build before the plan is grounded "
                "(codegraph + qmd) + reviewed; root-cause before any fix (3 failed hypotheses → escalate).\n")
    # 1a-ii) ship the STARTER SKILL PACK (distilled, vetted methodology) into every agent's skills/ so a
    #        fresh agent starts with craft, not empty. Never clobber a learned skill; merge skills/INDEX.md.
    sk_src = REPO / "skills"
    if sk_src.exists():
        sk_dst = home / "skills"; sk_dst.mkdir(exist_ok=True)
        for sf in sk_src.glob("*.md"):
            if sf.name == "INDEX.md":
                continue
            if not (sk_dst / sf.name).exists():
                _write(sk_dst / sf.name, sf.read_text())
        idx = sk_dst / "INDEX.md"
        if not idx.exists():
            _write(idx, (sk_src / "INDEX.md").read_text())
        else:
            cur = idx.read_text()
            add = [ln for ln in (sk_src / "INDEX.md").read_text().splitlines()
                   if ln.startswith("- **") and ln not in cur]
            if add:
                _write(idx, cur.rstrip() + "\n" + "\n".join(add) + "\n")
    csrc = tdir / ".claude"
    if csrc.exists():
        shutil.copytree(csrc, home / ".claude", dirs_exist_ok=True)
    # 1a) Co-locate the guard/logging hooks INSIDE the agent home so they ALWAYS resolve. The historical
    #     /workspace/platform/agentd/hooks/... path depends on a mount that isn't reliably present — and a
    #     missing-file PreToolUse hook exits 2, which the harness treats as BLOCK, silently killing every
    #     tool call in the pod. /agent is always mounted (claude reads .claude/settings.json from it), so
    #     ship the hooks alongside it and rewrite any legacy /workspace ref to the co-located path.
    hooks_src = REPO / "platform" / "agentd" / "hooks"
    if hooks_src.exists():
        shutil.copytree(hooks_src, home / ".claude" / "hooks",
                        ignore=shutil.ignore_patterns("__pycache__", "*.pyc"), dirs_exist_ok=True)
        setjson = home / ".claude" / "settings.json"
        if setjson.exists():
            setjson.write_text(setjson.read_text().replace(
                "/workspace/platform/agentd/hooks/", "/agent/.claude/hooks/"))
        elif (home / ".claude" / "hooks" / "guard.py").exists():
            # Template shipped NO settings.json (venture/autonomous/orchestrator) → write the default guard
            # hook so EVERY pod is guarded, not just templates that happen to include a settings.json.
            # Also wire delegation_guard (self-gates to BRAIN=claude; no-op for local/api workers) so a
            # capable manager is forced to delegate bulk code-writing to a cheap/local worker fleet-wide.
            _dg = [{"type": "command", "command": "python3 /agent/.claude/hooks/delegation_guard.py"}] \
                if (home / ".claude" / "hooks" / "delegation_guard.py").exists() else []
            _pre = [{"matcher": "Bash|Read|Edit|Write|NotebookEdit",
                     "hooks": [{"type": "command", "command": "python3 /agent/.claude/hooks/guard.py"}]}]
            if _dg:
                _pre.append({"matcher": "Write|Edit|MultiEdit", "hooks": _dg})
            # ctx_budget PreToolUse: once spend nears the package budget, BLOCK the work tools so the
            # agent can only finalize its handoff + finish (cost discipline; pairs with the PostToolUse warn).
            if (home / ".claude" / "hooks" / "ctx_budget.py").exists():
                _pre.append({"matcher": "Bash|Edit|MultiEdit|Task|WebFetch|WebSearch",
                    "hooks": [{"type": "command", "command": "python3 /agent/.claude/hooks/ctx_budget.py"}]})
            _hk = {"PreToolUse": _pre}
            # PostToolUse: verify_edit runs a fast per-file syntax/parse check after an edit and feeds a
            # real breakage back to the agent — the mechanical first-gate of the verify-before-done skill.
            _post = []
            if (home / ".claude" / "hooks" / "verify_edit.py").exists():
                _post.append({"matcher": "Write|Edit|MultiEdit",
                    "hooks": [{"type": "command", "command": "python3 /agent/.claude/hooks/verify_edit.py"}]})
            # ctx_budget: after EVERY tool, warn the agent when its context nears its planned package
            # budget so it banks a handoff + clears before the session balloons (cost discipline).
            if (home / ".claude" / "hooks" / "ctx_budget.py").exists():
                _post.append({"matcher": "*",
                    "hooks": [{"type": "command", "command": "python3 /agent/.claude/hooks/ctx_budget.py"}]})
            if _post:
                _hk["PostToolUse"] = _post
            _write(setjson, json.dumps({"hooks": _hk}, indent=2) + "\n")
    # 1a-iii) ship the VERIFIER SUBAGENTS into home/.claude/agents so a BRAIN=claude agent's verifier-gate
    #         can spawn them by type (Task tool: code-reviewer / silent-failure-hunter / security-reviewer).
    #         Read-only review agents; harmless for local/api brains (they have no Task tool — skills cover them).
    ag_src = REPO / "agents"
    if ag_src.exists():
        ag_dst = home / ".claude" / "agents"; ag_dst.mkdir(parents=True, exist_ok=True)
        for af in ag_src.glob("*.md"):
            if not (ag_dst / af.name).exists():
                _write(ag_dst / af.name, af.read_text())
    # 1b) GENERATE .mcp.json from the memory choices — only enabled servers, never a dead entry.
    mcp_servers = {}
    if qmd_url:
        mcp_servers["qmd"] = {"type": "http", "url": qmd_url}
    if cg_corpus:
        # codegraph runs as THIS agent's own compose service → reached by service name on the agent's
        # PRIVATE compose network (never host-published), so no other agent's container can touch it.
        mcp_servers["codegraph"] = {"type": "http", "url": "http://codegraph:18184/mcp"}
    _write(home / ".mcp.json", json.dumps({"mcpServers": mcp_servers}, indent=2) + "\n")
    # 1c) BRAIN=optimize: the editable pool config route_brain reads (agent-dir policy.json wins over baked).
    if brain == "optimize":
        _write(home / "policy.json", json.dumps(opt_policy, indent=2) + "\n")

    # 2) agent.env (runtime defaults; NO inline comments after values — loader keeps everything after '=')
    lines = [
        "# Agent runtime config. NO inline comments after values.",
        f"AGENT_ID={name}",
        f"BRAIN={brain}",
    ]
    if brain == "claude":
        lines.append(f"MODEL={model}")
    elif brain == "optimize":
        # MODEL = top/judgment Claude model; MODEL_ROUTINE = cheap/mechanical Claude model. route_brain
        # reads both, then shifts to a policy.json pool as the cap fills (pools resolved at tick time).
        lines.append(f"MODEL={model}")
        lines.append("MODEL_ROUTINE=claude-sonnet-4-6")
    else:
        lines.append(f"BRAIN_MODEL={model}")
        if brain == "local":
            lines.append("BRAIN_API_BASE=http://host.docker.internal:11434/v1")
    lines += ["RUNTIME_MODE=daemon", "INTERVAL_SECONDS=86400", "PERMISSION=dangerous", "TOOLS_ROOT=/workspace"]
    # Carry any extra knobs the template ships in its agent.env (e.g. GUARD_CLOUD_READONLY=1 for analyst)
    # that the wizard didn't already set — so a template can declare its own profile.
    already = {ln.split("=", 1)[0] for ln in lines if "=" in ln}
    tenv = tdir / "agent.env"
    if tenv.exists():
        for ln in tenv.read_text().splitlines():
            ln = ln.strip()
            if ln and not ln.startswith("#") and "=" in ln and ln.split("=", 1)[0] not in already:
                lines.append(ln)
    _write(home / "agent.env", "\n".join(lines) + "\n")

    # 3) runtime I/O files
    _write(home / "inbox.md", f"# inbox — initialized {time.strftime('%Y-%m-%d')}\n\n")
    _write(home / "work.json", "[]\n")          # BARE list — memory.py requires it (not {"items":[]})
    # bin/memory.py — shim so the brain's CLAUDE.md `python3 /agent/bin/memory.py …` resolves to the
    # framework memory.py baked in the image. runtime.sh already falls back; the BRAIN's literal command
    # needs this too, else every recall/remember/work-list call fails (it was missing → agents ran blind).
    _write(home / "bin" / "memory.py",
           '#!/usr/bin/env python3\n'
           '"""Shim -> the framework memory.py baked in the image (CLAUDE.md calls /agent/bin/memory.py)."""\n'
           'import os, sys\n'
           'for _p in ("/workspace/platform/agentd/memory.py",\n'
           '           os.path.join(os.environ.get("TOOLS_ROOT", "/workspace"), "platform/agentd/memory.py")):\n'
           '    if os.path.exists(_p):\n'
           '        os.execv(sys.executable, [sys.executable, _p, *sys.argv[1:]])\n'
           'sys.stderr.write("memory.py shim: framework memory.py not found\\n"); sys.exit(127)\n')
    try:
        os.chmod(home / "bin" / "memory.py", 0o755)
    except OSError:
        pass
    _write(home / "state" / "rollup.md", f"# {name} status\n\n(no ticks yet)\n")
    (home / "logs").mkdir(parents=True, exist_ok=True)
    # default working folder (mounted at /work) lives inside the vault unless WORK_DIR points elsewhere
    (home / "work").mkdir(parents=True, exist_ok=True)
    _write(home / "work" / ".gitkeep", "")
    (home / "outputs").mkdir(parents=True, exist_ok=True)   # agent deliverables the operator downloads via the chat
    _write(home / "outputs" / ".gitkeep", "")

    # 4) knowledge wiki = the portable default memory (no DB/GPU/service)
    wiki = REPO / "platform" / "agentd" / "wiki.py"
    if wiki.exists():
        r = subprocess.run([sys.executable, str(wiki), "init", "knowledge"], cwd=home)
        if r.returncode != 0:
            print("  (wiki init returned nonzero — continuing; you can run it later)")

    # 5) secrets/ (read-only creds, written 600 inside a 700 dir)
    secrets.mkdir(mode=0o700, parents=True, exist_ok=True)
    try:
        os.chmod(secrets, 0o700)
    except OSError:
        pass
    if bspec["secret_file"]:
        sfile = secrets / bspec["secret_file"]
        if cred:
            _write(sfile, f"{bspec['secret_key']}={cred}\n", mode=0o600)
        elif not sfile.exists():
            _write(sfile, f"# add your credential here, no quotes:\n{bspec['secret_key']}=\n", mode=0o600)
    # 5b) BRAIN=optimize: one secrets/<pool>.env per remote pool (route_brain resolves keys by env-var name).
    for fname, body in (opt_secret_envs or {}).items():
        spath = secrets / fname
        if not spath.exists():
            _write(spath, body, mode=0o600)
    # ensure anthropic.env exists so compose's env_file never errors (it's required:false anyway)
    apath = secrets / "anthropic.env"
    if not apath.exists():
        _write(apath, "# Claude Code OAuth token (BRAIN=claude). Leave blank for other brains.\nCLAUDE_CODE_OAUTH_TOKEN=\n", mode=0o600)

    # 6) .env (compose-level interpolation: AGENT_ID/BRAIN/MODEL/.../WEB_CHAT_*)
    env_lines = [
        f"AGENT_ID={name}",
        f"BRAIN={brain}",
        f"MODEL={model}",
        "RUNTIME_MODE=daemon",
        "INTERVAL_SECONDS=86400",
        "PERMISSION=dangerous",
        f"WEB_CHAT_BIND={bind}",
        f"WEB_CHAT_TOKEN={token}",
    ]
    if cg_corpus:
        env_lines.append(f"CODE_CORPUS={cg_corpus}")   # `enclave run` brings up the codegraph bridge over this
    # WORK_DIR: blank → compose default (./home/work). A host path makes that tree the working folder.
    env_lines.append(f"WORK_DIR={work_dir}" if work_dir else "# WORK_DIR=/abs/path/to/project   # host working folder (mounted rw at /work); blank = home/work")
    if image_only:
        # pin the shared prebuilt images so this deployment never builds its own runtime — improvements
        # land by rebuilding the image once + `enclave fleet restart`. Override the tags via flags.
        env_lines.append(f"ENCLAVE_AGENT_IMAGE={_flag(args, '--agent-image', 'enclave-agent:latest')}")
        env_lines.append(f"ENCLAVE_CHAT_IMAGE={_flag(args, '--chat-image', 'enclave-chat:latest')}")
    _write(envf, "\n".join(env_lines) + "\n")
    # image-only deployments still need a compose file (they reference the shared image). Copy the
    # canonical one if the deployment doesn't have its own.
    if image_only and not (DEPLOY / "docker-compose.yml").exists():
        shutil.copy2(REPO / "docker-compose.yml", DEPLOY / "docker-compose.yml")

    # 7b) spec extras (mission/kpi → CLAUDE.md, interval, scoped-secret placeholders, guardrails)
    if spec:
        _apply_spec_extras(spec, home, secrets, envf)
    # 7c) allow_git: credential-helper push setup (agent pushes without seeing the raw token)
    if allow_git:
        _setup_git_push(home, secrets, name)

    # 7) make the vault durable BY DEFAULT — its own scan-gated git repo (secrets/ excluded, a
    # fail-closed pre-commit hook blocks any credential). So memory survives a machine wipe safely.
    vault = _init_vault_git(home)

    print(f"\n✓ Configured agent '{name}' (brain={brain}, model={model}, template={tpl}).")
    if vault == "created":
        print(f"  vault    → home/ is a git repo (memory saved on `enclave snapshot`; secrets/ excluded + scan-gated)")
    print(f"  home/    → mounts to /agent (CLAUDE.md, agent.env, work.json, knowledge/ wiki)")
    mem = ["wiki (always-on)"] + (["qmd"] if qmd_url else []) + (["codegraph→" + cg_corpus] if cg_corpus else [])
    print(f"  memory   → {', '.join(mem)}" + ("  ·  codegraph bridge starts on `enclave run`" if cg_corpus else ""))
    print(f"  /work    → {work_dir or 'home/work'} (rw working folder — where the agent saves work; index it for recall, see docs/WORK-DIR.md)")
    needs_cred = bool(bspec["secret_key"])
    cred_present = bool(cred)
    if needs_cred and not cred_present:  # maybe it's already in the file from a prior setup
        sfile = secrets / bspec["secret_file"]
        if sfile.exists():
            for ln in sfile.read_text().splitlines():
                if ln.startswith(bspec["secret_key"] + "=") and ln.split("=", 1)[1].strip():
                    cred_present = True; break
    print(f"  secrets/ → read-only creds" + ("  ⚠ credential not set yet" if (needs_cred and not cred_present) else ""))
    print(f"  .env     → compose config (chat on http://{bind}/)")
    if needs_cred and not cred_present:
        print(f"\n  ⚠ Add your credential before running:")
        print(f"      echo '{bspec['secret_key']}=<your-key>' > secrets/{bspec['secret_file']} && chmod 600 secrets/{bspec['secret_file']}")
    # offer to run
    if _interactive() and not yes:
        if _ask("Start the agent now?", default="y", choices=["y", "n"]) == "y":
            return cmd_run([])
    print("\nNext: enclave run   (build + start + open the browser)")


# ── run / lifecycle ──────────────────────────────────────────────────────────
def _read_env(key, default=None):
    envf = DEPLOY / ".env"
    if envf.exists():
        for line in envf.read_text().splitlines():
            line = line.strip()
            if line and not line.startswith("#") and line.split("=", 1)[0] == key:
                return line.split("=", 1)[1]
    return default

def _set_env_kv(path, updates, remove=()):
    """Update/append KEY=VALUE lines in an env file, preserving order + comments. `remove` drops keys.
    NO inline comments after values (the runtime loader keeps everything after '=')."""
    lines = path.read_text().splitlines() if path.exists() else []
    out, seen = [], set()
    for ln in lines:
        s = ln.strip()
        if s and not s.startswith("#") and "=" in s:
            k = s.split("=", 1)[0]
            if k in remove:
                continue
            if k in updates:
                out.append(f"{k}={updates[k]}"); seen.add(k); continue
        out.append(ln)
    for k, v in updates.items():
        if k not in seen:
            out.append(f"{k}={v}")
    _write(path, "\n".join(out) + "\n")

def _secret_set(path, key):
    """True if env-file `path` defines `key` with a non-empty value."""
    try:
        for ln in path.read_text().splitlines():
            if ln.strip().startswith(key + "=") and ln.split("=", 1)[1].strip():
                return True
    except Exception:
        pass
    return False

def _open_browser(url):
    import webbrowser
    try:
        if webbrowser.open(url):
            return True
    except Exception:
        pass
    for cmd in (["open", url], ["xdg-open", url], ["cmd", "/c", "start", "", url]):
        try:
            if subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode == 0:
                return True
        except FileNotFoundError:
            continue
    return False

def _wait_reachable(url, timeout=40):
    deadline = time.time() + timeout
    while time.time() < deadline:
        try:
            with urllib.request.urlopen(url, timeout=2) as r:
                if r.status < 500:
                    return True
        except Exception:
            time.sleep(1)
    return False

def _ensure_codegraph_bridge():
    """If CODE_CORPUS is set in .env, bring up THIS agent's codegraph as its OWN compose SERVICE (profile
    'codegraph') over that repo. Running it inside the agent's compose project puts it on the project's
    PRIVATE network — reachable ONLY by this agent, by service name `codegraph` (http://codegraph:18184/mcp),
    NEVER host-published. So one agent's codegraph (and the repo it indexes) can't be reached by any other
    agent's container — isolation is structural, per-agent, by construction. Idempotent."""
    corpus = os.path.expanduser(_read_env("CODE_CORPUS", "") or "")
    if not corpus:
        return
    if not os.path.isdir(corpus):
        print(f"  ⚠ CODE_CORPUS={corpus} not found — codegraph not started."); return
    img = "enclave-codegraph:latest"
    if subprocess.run(["docker", "image", "inspect", img], capture_output=True).returncode != 0:
        print("  building codegraph image…")
        subprocess.run(["docker", "build", "-f", "Dockerfile.codegraph", "-t", img, "."], cwd=REPO)
    # First run: build the index (reembed) via the SAME compose service (so the corpus mount matches serve).
    if not os.path.isdir(os.path.join(corpus, ".codegraph")):
        print(f"  indexing {corpus} for codegraph (first run — a few minutes)…")
        subprocess.run(["docker", "compose", "run", "--rm", "-e", "CODEGRAPH_MODE=reembed", "codegraph"], cwd=DEPLOY)
    # Serve it on the agent's PRIVATE compose network (no host port; reachable only within the project).
    r = subprocess.run(["docker", "compose", "--profile", "codegraph", "up", "-d", "codegraph"],
                       cwd=DEPLOY, capture_output=True, text=True)
    print(f"  codegraph up → http://codegraph:18184/mcp (PRIVATE to this agent; corpus: {corpus})"
          if r.returncode == 0 else f"  ⚠ codegraph failed: {r.stderr.strip()[:160]}")

def _check_chat_js():
    """Build-time guard: run check_chat_js.py so a JS syntax error in the rendered chat PAGE
    fails the build instead of shipping a dead UI (web_chat.PAGE is a non-raw string — a single
    backslash in an inline regex silently breaks it). Non-blocking if the checker/node is absent."""
    checker = REPO / "platform" / "agentd" / "check_chat_js.py"
    if not checker.exists():
        return
    r = subprocess.run([sys.executable, str(checker)], cwd=REPO)
    if r.returncode == 1:   # 1 = a real JS syntax error; 2/other = setup issue → don't block
        sys.exit("Aborting build — fix the chat UI JavaScript above before deploying.")


def _docker_ok():
    """Preflight: Docker installed AND the daemon reachable — a friendly message, not a raw stack trace."""
    if not shutil.which("docker"):
        sys.exit("Docker isn't installed. Install Docker Desktop (https://www.docker.com) and start it, then retry.")
    if subprocess.run(["docker", "info"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode != 0:
        sys.exit("Docker is installed but the daemon isn't running. Start Docker Desktop (or `dockerd`), then retry.")


def cmd_run(args):
    if not (DEPLOY / "docker-compose.yml").exists():
        sys.exit("No docker-compose.yml in the deployment — is this an Enclave checkout/deployment?")
    _docker_ok()
    home = DEPLOY / "home"
    if not home.exists() or not any(p.name != ".gitkeep" for p in home.iterdir()):
        sys.exit("./home is not configured — run 'enclave init' first.")

    # --pull: fetch prebuilt images from the registry (set ENCLAVE_AGENT_IMAGE/ENCLAVE_CHAT_IMAGE in .env)
    # instead of a local build. Otherwise build locally unless --no-build.
    if _has(args, "--pull"):
        print("Pulling prebuilt images…")
        subprocess.run(["docker", "compose", "pull"], cwd=DEPLOY)
        build = False
    else:
        build = not _has(args, "--no-build")
    if build:
        _check_chat_js()
    cmd = ["docker", "compose", "up", "-d"] + (["--build"] if build else [])
    print("Starting Enclave (docker compose up)…")
    r = subprocess.run(cmd, cwd=DEPLOY)
    if r.returncode != 0:
        sys.exit(r.returncode)

    _ensure_codegraph_bridge()   # opt-in code memory (CODE_CORPUS in .env) — twin of the qmd gateway

    bind = _read_env("WEB_CHAT_BIND", "127.0.0.1:8888")
    host, _, port = bind.partition(":")
    host = host or "127.0.0.1"
    port = port or "8888"
    token = _read_env("WEB_CHAT_TOKEN", "")
    url = f"http://{host}:{port}/" + (f"?token={token}" if token else "")

    if _has(args, "--no-open"):
        print(f"\nAgent running. Chat: {url}")
        return

    print(f"\nWaiting for the chat UI at http://{host}:{port}/ …")
    if _wait_reachable(f"http://{host}:{port}/", timeout=40):
        if _open_browser(url):
            print(f"Opened {url} in your browser.")
        else:
            print(f"Could not auto-open a browser. Open it manually: {url}")
    else:
        print(f"Chat UI not reachable yet (the agent may still be building). Try: {url}")
        print("  enclave logs   # to watch startup")

def cmd_stop(args):
    subprocess.run(["docker", "compose", "down"], cwd=DEPLOY)

def cmd_publish(args):
    """Maintainer: build + push the agent/chat images to a registry so teammates can `run --pull`.
    Single-arch by default (the maintainer's arch). --platform linux/amd64,linux/arm64 does a MULTI-ARCH
    buildx push so x86 teammates work too (needs Docker buildx + QEMU; emulated builds are slow)."""
    reg = _flag(args, "--registry") or _read_env("ENCLAVE_REGISTRY") or os.environ.get("ENCLAVE_REGISTRY")
    if not reg:
        sys.exit("Set a registry: enclave publish --registry ghcr.io/<owner>   "
                 "(login first: docker login ghcr.io)")
    _check_chat_js()    # don't publish an image with a broken chat UI
    tag = _flag(args, "--tag", "latest")
    platform = _flag(args, "--platform")    # e.g. "linux/amd64,linux/arm64" → multi-arch buildx push
    multi = bool(platform and "," in platform)
    targets = [("Dockerfile.agent", f"{reg}/enclave-agent:{tag}"),
               ("Dockerfile.chat", f"{reg}/enclave-chat:{tag}")]

    if multi:
        # buildx multi-arch MUST build+push in one step (a manifest list can't be `docker push`ed after).
        if subprocess.run(["docker", "buildx", "version"], cwd=REPO,
                          stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode != 0:
            sys.exit("docker buildx not available — install Docker Desktop / the buildx plugin for multi-arch.")
        # Ensure a builder that can emulate other arches (QEMU). Idempotent: create-or-reuse 'enclave-mx'.
        if subprocess.run(["docker", "buildx", "inspect", "enclave-mx"], cwd=REPO,
                          stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode != 0:
            subprocess.run(["docker", "buildx", "create", "--name", "enclave-mx", "--use"], cwd=REPO)
        else:
            subprocess.run(["docker", "buildx", "use", "enclave-mx"], cwd=REPO)
        print(f"⏳ multi-arch build ({platform}) — emulated arches are slow, this can take a while.")
        for dockerfile, ref in targets:
            print(f"\n=== buildx build+push {ref}  [{platform}] ===")
            if subprocess.run(["docker", "buildx", "build", "--platform", platform,
                               "-f", dockerfile, "-t", ref, "--push", "."], cwd=REPO).returncode != 0:
                sys.exit(f"buildx build+push failed for {ref} — logged in to {reg.split('/')[0]}?")
    else:
        if platform:
            print(f"(single-arch build for {platform})")
        for dockerfile, ref in targets:
            print(f"\n=== build + push {ref} ===")
            build = ["docker", "build"] + (["--platform", platform] if platform else []) + \
                    ["-f", dockerfile, "-t", ref, "."]
            if subprocess.run(build, cwd=REPO).returncode != 0:
                sys.exit(f"build failed for {ref}")
            if subprocess.run(["docker", "push", ref], cwd=REPO).returncode != 0:
                sys.exit(f"push failed for {ref} — is `docker login {reg.split('/')[0]}` done?")
    print("\nPublished" + (f" (multi-arch {platform})" if multi else "") + ":")
    for _, ref in targets:
        print(f"  {ref}")
    print("\nTeammates: set these in .env, then `enclave run --pull`:")
    print(f"  ENCLAVE_AGENT_IMAGE={targets[0][1]}")
    print(f"  ENCLAVE_CHAT_IMAGE={targets[1][1]}")

def cmd_logs(args):
    log = DEPLOY / "home" / "logs" / "runner.log"
    if log.exists():
        subprocess.run(["tail", "-f", str(log)])
    else:
        subprocess.run(["docker", "compose", "logs", "-f", "agent"], cwd=DEPLOY)

def cmd_send(args):
    if not args:
        sys.exit("Usage: enclave send <message>")
    message = " ".join(a for a in args if not a.startswith("--"))
    inbox = DEPLOY / "home" / "inbox.md"
    ts = time.strftime("%Y-%m-%dT%H:%MZ", time.gmtime())
    inbox.parent.mkdir(parents=True, exist_ok=True)
    with inbox.open("a") as f:
        f.write(f"\n\n---\n**[Operator at {ts}]**\n\n{message}\n\n*Reply by writing to state/chat-reply.md*\n")
    print(f"Delivered to {inbox}")

def cmd_status(args):
    state = DEPLOY / "home" / "state"
    rollup = state / "rollup.md"
    if rollup.exists():
        print("=== Status ===")
        print(rollup.read_text()[-2000:])
    hb = state / ".heartbeat"
    if hb.exists():
        try:
            age = int(time.time()) - int(hb.read_text().strip())
            print(f"\nLast heartbeat: {age}s ago")
        except ValueError:
            pass

def cmd_chat(args):
    data = DEPLOY / "home"
    inbox = data / "inbox.md"
    reply_file = data / "state" / "chat-reply.md"
    print("Terminal chat — type a message, Enter to send. Ctrl-C to exit.\n")
    last = None
    try:
        last = reply_file.stat().st_mtime
    except OSError:
        pass
    while True:
        try:
            msg = input("You: ").strip()
        except (KeyboardInterrupt, EOFError):
            print("\nExiting."); break
        if not msg:
            continue
        ts = time.strftime("%Y-%m-%dT%H:%MZ", time.gmtime())
        inbox.parent.mkdir(parents=True, exist_ok=True)
        with inbox.open("a") as f:
            f.write(f"\n\n---\n**[Operator at {ts}]**\n\n{msg}\n\n*Write your reply to state/chat-reply.md*\n")
        print("(delivered — waiting for reply…)")
        deadline = time.time() + 600
        while time.time() < deadline:
            time.sleep(2)
            try:
                m = reply_file.stat().st_mtime
            except OSError:
                continue
            if m != last:
                content = ""
                try:
                    content = reply_file.read_text().strip()
                except OSError:
                    pass
                if content:
                    last = m
                    print(f"\nAgent: {content}\n")
                    try:
                        reply_file.write_text("")
                    except OSError:
                        pass
                    break
        else:
            print("(no reply yet — the agent may still be working)")


def cmd_new(args):
    """Scaffold a NEW deployment in its OWN folder — you name the folder AND the agent/container.
    Usage: enclave new <agent-name> [--dir <path>] [--image-only] [--spec f] [init flags…]
      <agent-name>  becomes AGENT_ID (container names + compose project + a free port chosen for you)
      --dir <path>  where to place it (default: a sibling folder named <agent-name>)
      --image-only  LIGHTWEIGHT deployment: only .env/docker-compose.yml/home/secrets, referencing the
                    shared prebuilt image (no per-agent runtime copy) so central rebuilds propagate.
    Default copies this product (minus home/secrets/.env) → the new folder; --image-only copies only the
    compose file. Either way it runs `init` in the new folder."""
    name = next((a for a in args if not a.startswith("-")), None)
    if not name:
        sys.exit("Usage: enclave new <agent-name> [--dir <path>] [--image-only]")
    rest = [a for a in args if a != name]
    target = pathlib.Path(_flag(args, "--dir") or (REPO.parent / name)).expanduser()
    if "--dir" in rest:
        i = rest.index("--dir"); del rest[i:i+2]
    if target.exists() and any(target.iterdir()):
        sys.exit(f"{target} already exists and is non-empty — pick another --dir or name.")

    if _has(rest, "--image-only"):
        # Lightweight: no product copy. Source assets (templates/, platform/, Dockerfiles) come from
        # THIS canonical checkout; init writes home/secrets/.env into the target via DEPLOY.
        print(f"Scaffolding lightweight (shared-image) deployment '{name}' → {target} …")
        target.mkdir(parents=True, exist_ok=True)
        global DEPLOY
        DEPLOY = target.resolve()
        cmd_init(["--name", name, *rest])    # rest still carries --image-only (+ any --spec / flags)
        print(f"\n✓ '{name}' ready at {target} (shared image).  Start:  enclave run --dir {target} --no-build")
        return

    print(f"Scaffolding Enclave deployment '{name}' → {target} …")
    ignore = shutil.ignore_patterns("home", "secrets", ".env", ".git", "__pycache__", "*.pyc",
                                    "outputs", "RESUME.md", "RESUME.md.bak", "deploy", "marketing")
    shutil.copytree(REPO, target, ignore=ignore)
    # configure it in place (free port + this name); pass through any extra init flags (--brain, --yes, …)
    rc = subprocess.run([sys.executable, str(target / "bin" / "enclave"), "init", "--name", name, *rest],
                        cwd=str(target)).returncode
    if rc == 0:
        print(f"\n✓ '{name}' ready at {target}.  Next:  cd {target} && ./bin/enclave run")
    sys.exit(rc)

def cmd_app(args):
    """macOS: install an /Applications launcher (.app). By default it starts THIS deployment's containers
    + opens its chat. With --console (alias --fleet) it instead launches the web FLEET CONSOLE (:8700) —
    the control panel for ALL agents on this host (start/stop/restart/logs). Double-click in Launchpad.
    Usage: enclave app [--console] [--dir /Applications] [--port 8700]"""
    if sys.platform != "darwin":
        sys.exit("`enclave app` is macOS-only (it builds an /Applications .app launcher).")
    if not shutil.which("osacompile"):
        sys.exit("osacompile not found — install Xcode command line tools (`xcode-select --install`).")
    appdir = pathlib.Path(_flag(args, "--dir") or "/Applications")

    # --console / --fleet: a launcher for the whole-host control panel, not a single agent.
    if _has(args, "--console") or _has(args, "--fleet"):
        cport = _flag(args, "--port") or os.environ.get("CONSOLE_PORT") or "8700"
        ctok = os.environ.get("CONSOLE_TOKEN", "")
        curl = f"http://127.0.0.1:{cport}/" + (f"?token={ctok}" if ctok else "")
        appname = "Enclave Fleet"
        apppath = appdir / f"{appname}.app"
        # Start the console detached (idempotent: a 2nd bind on the port just exits to the log), then open it.
        script = (
            'set repo to "%s"\n'
            'display notification "Opening the Enclave fleet console…" with title "Enclave"\n'
            'do shell script "cd " & quoted form of repo & " && PATH=/usr/local/bin:/opt/homebrew/bin:$PATH '
            'nohup ./bin/enclave console --no-open --port %s >/tmp/enclave-console.log 2>&1 &"\n'
            'delay 1.5\n'
            'open location "%s"\n'
        ) % (str(REPO), cport, curl)
        import tempfile as _tf
        src = _tf.NamedTemporaryFile("w", suffix=".applescript", delete=False); src.write(script); src.close()
        try:
            if apppath.exists():
                shutil.rmtree(apppath)
            r = subprocess.run(["osacompile", "-o", str(apppath), src.name])
        finally:
            os.unlink(src.name)
        if r.returncode != 0:
            sys.exit("osacompile failed.")
        print(f"✓ Installed fleet launcher: {apppath}")
        print(f"  Double-click '{appname}' in Applications / Launchpad → opens the fleet console at {curl}")
        print(f"  (Control ALL agents from there: start / stop / restart / logs / chat.)")
        return

    name = _read_env("AGENT_ID", "enclave-agent")
    bind = _read_env("WEB_CHAT_BIND", "127.0.0.1:8888")
    host, _, port = bind.partition(":"); url = f"http://{host or '127.0.0.1'}:{port or '8888'}/"
    appname = f"Enclave – {name}"
    apppath = appdir / f"{appname}.app"
    # AppleScript: bring the stack up (existing images, no browser) then open the chat URL.
    script = (
        'set repo to "%s"\n'
        'display notification "Starting %s…" with title "Enclave"\n'
        'do shell script "cd " & quoted form of repo & " && PATH=/usr/local/bin:/opt/homebrew/bin:$PATH '
        './bin/enclave run --no-open --no-build >/tmp/enclave-%s.log 2>&1"\n'
        'delay 1\n'
        'open location "%s"\n'
    ) % (str(REPO), name, name, url)
    import tempfile
    src = tempfile.NamedTemporaryFile("w", suffix=".applescript", delete=False); src.write(script); src.close()
    try:
        if apppath.exists():
            shutil.rmtree(apppath)
        r = subprocess.run(["osacompile", "-o", str(apppath), src.name])
    finally:
        os.unlink(src.name)
    if r.returncode != 0:
        sys.exit("osacompile failed.")
    print(f"✓ Installed launcher: {apppath}")
    print(f"  Find '{appname}' in Applications / Launchpad (or double-click it) to start the agent + open the chat.")
    print(f"  (Run `enclave run` once first so the images are built; the launcher uses existing images.)")

PRODUCT_PATHS = ["platform", "bin", "templates", "docs", "README.md", "SECURITY.md",
                 "Dockerfile.agent", "Dockerfile.chat", "Dockerfile.relay",
                 "Dockerfile.qmd", "Dockerfile.codegraph"]

def cmd_update(args):
    """Update THIS deployment's Enclave runtime to the latest + rebuild — preserving home/, secrets/,
    .env, and your local docker-compose.yml. Works for git-clone AND `enclave new` (non-git) deployments.
    Usage: enclave update [--from <product-dir>] [--pull] [--branch B] [--no-build] [--force-compose]
      --pull   prebuilt-image mode: docker compose pull + recreate (no source refresh)
      --from   copy runtime files from a local product checkout (for non-git deployments)
      (no flag) git-clone deployments fetch origin and refresh the runtime paths"""
    if not (REPO / "docker-compose.yml").exists():
        sys.exit("Not an Enclave deployment (no docker-compose.yml here).")
    # 1) prebuilt-image mode — the image carries the code; just pull + recreate
    if _has(args, "--pull") or _read_env("ENCLAVE_AGENT_IMAGE"):
        print("Updating via prebuilt images (docker compose pull)…")
        subprocess.run(["docker", "compose", "pull"], cwd=REPO)
        subprocess.run(["docker", "compose", "up", "-d"], cwd=REPO)
        print("✓ updated (pulled images + recreated)."); return
    # 2) build-from-source mode — refresh the runtime files, then rebuild
    src = _flag(args, "--from")
    if src:
        src = pathlib.Path(src).expanduser().resolve()
        if not (src / "platform" / "agentd").exists():
            sys.exit(f"{src} doesn't look like an Enclave product (no platform/agentd/).")
        if src == REPO:
            sys.exit("--from is this same folder; point it at a different product checkout.")
        for p in PRODUCT_PATHS:
            s = src / p
            if not s.exists():
                continue
            d = REPO / p
            if s.is_dir():
                shutil.copytree(s, d, dirs_exist_ok=True)
            else:
                shutil.copy2(s, d)
        print(f"✓ runtime files copied from {src} (home/secrets/.env/compose preserved).")
        if not _has(args, "--force-compose") and (src / "docker-compose.yml").exists():
            try:
                if (src / "docker-compose.yml").read_text() != (REPO / "docker-compose.yml").read_text():
                    print("  ⚠ docker-compose.yml differs from the source — NOT overwritten (your deployment "
                          "edits preserved). Review manually, or pass --force-compose to take the product's.")
            except OSError:
                pass
    elif (REPO / ".git").exists():
        branch = _flag(args, "--branch", "main")
        print(f"Fetching origin/{branch}…")
        if subprocess.run(["git", "fetch", "origin", branch], cwd=REPO).returncode != 0:
            sys.exit("git fetch failed (check the remote/credentials), or pass --from <product-dir>.")
        for p in PRODUCT_PATHS:                      # refresh only runtime paths; keep local compose/.env/home/secrets
            subprocess.run(["git", "checkout", f"origin/{branch}", "--", p], cwd=REPO,
                           stderr=subprocess.DEVNULL)
        subprocess.run(["git", "reset", "-q"], cwd=REPO)   # unstage (a deployment isn't committed)
        print(f"✓ runtime files refreshed from origin/{branch} (compose/.env/home/secrets preserved).")
    else:
        sys.exit("This deployment isn't a git clone. Pass --from <product-dir> (a checkout of the "
                 "enclave repo) — e.g. `enclave update --from ~/Dev/enclave` — or use --pull for images.")
    if _has(args, "--no-build"):
        print("  (skipped rebuild — run `enclave run` to apply)"); return
    _check_chat_js()
    print("Rebuilding + recreating…")
    subprocess.run(["docker", "compose", "up", "-d", "--build"], cwd=REPO)
    print("✓ updated + live.")


def cmd_console(args):
    """Launch the web fleet console PLUS the background services that make its buttons work
    (create-agent, apply-fix, health monitor) — one command = a fully-wired dashboard.

    Usage: enclave console [--port N] [--no-open] [--no-watchers] [--no-monitor]
      --no-watchers  console only — create-agent & apply-fix stay inert (you run the watchers yourself)
      --no-monitor   run the watchers but not the health-monitor daemon (Monitor view stays empty)
    Env: CONSOLE_TOKEN (loopback gate). Agents are discovered under ENCLAVE_STACKS_ROOTS
    (default: this checkout's parent dir, where `enclave new` puts sibling deployments)."""
    _docker_ok()
    script = REPO / "platform" / "agentd" / "console.py"
    if not script.exists():
        sys.exit("console.py not found in this build.")
    agentd = REPO / "platform" / "agentd"
    env = os.environ.copy()
    # Self-contained defaults so the dashboard is fully wired out of the box (override via env).
    stacks = env.get("ENCLAVE_STACKS_ROOTS") or str(REPO.parent)   # sibling deployments live here
    env["ENCLAVE_STACKS_ROOTS"] = stacks
    root0 = pathlib.Path(stacks.split(":")[0]).expanduser()
    spawn_q = env.get("ENCLAVE_SPAWN_QUEUE") or str(root0 / "_queue")
    control_q = env.get("ENCLAVE_CONTROL_QUEUE") or str(root0 / "_control")
    env["ENCLAVE_SPAWN_QUEUE"], env["ENCLAVE_CONTROL_QUEUE"] = spawn_q, control_q
    cfgdir = pathlib.Path(env.get("XDG_CONFIG_HOME") or (pathlib.Path.home() / ".config")) / "enclave"
    env.setdefault("ENCLAVE_MONITOR_HEARTBEAT", str(cfgdir / "monitor-heartbeat.json"))
    env.setdefault("ENCLAVE_MONITOR_STATE", str(cfgdir / "monitor-state.json"))
    for q in (spawn_q, control_q):
        for sub in ("incoming", "processed", "failed"):
            pathlib.Path(q, sub).mkdir(parents=True, exist_ok=True)

    procs = []   # background services, terminated when the console exits

    def _bg(label, name, *a):
        try:
            procs.append((label, subprocess.Popen([sys.executable, str(agentd / name), *a], env=env,
                          stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)))
            return True
        except Exception as e:
            print(f"  (couldn't start {name}: {e})"); return False

    if not _has(args, "--no-watchers"):
        started = []
        if _bg("create-agent", "spawn_watcher.py", spawn_q): started.append("create-agent")
        if _bg("apply-fix", "control_watcher.py", control_q): started.append("apply-fix/lifecycle")
        if not _has(args, "--no-monitor") and _bg("monitor", "fleet_monitor.py", control_q, "--interval", "60"):
            started.append("health-monitor")
        if started:
            print("Background services started: " + ", ".join(started))

    port = _flag(args, "--port") or env.get("CONSOLE_PORT") or str(_free_port(8700))
    tok = env.get("CONSOLE_TOKEN", "")
    url = f"http://127.0.0.1:{port}/" + (f"?token={tok}" if tok else "")
    if not _has(args, "--no-open"):
        import threading as _t
        _t.Timer(1.5, lambda: _open_browser(url)).start()
    print(f"Fleet console → {url}  (Ctrl-C to stop)")
    try:
        subprocess.run([sys.executable, str(script), "--port", str(port)], env=env)
    finally:
        for _label, p in procs:
            try: p.terminate()
            except Exception: pass


def cmd_fleet(args):
    """Fleet control plane across ALL Enclave deployments on this host (discovers via `docker compose ls`).
    Usage: enclave fleet [list] [--json] | open|up|down|restart|kick|logs <id> | send <id> <text>
           enclave fleet watch <queue-dir> [--stacks-root D] [--interval S] [--once]
           enclave fleet control-watch <queue-dir> [--interval S] [--once]
           enclave fleet monitor [<control-queue>] [--interval S] [--once] [--dry-run]
    `watch` runs the spawn watcher: a host daemon that turns specs dropped in <queue-dir>/incoming into
    running deployments (the manager-spawns-agents pattern — see docs/SPAWN.md).
    `control-watch` runs the control watcher: the lifecycle twin — specs request up|down|restart|kick|
    logs|send against an EXISTING agent (the manager-controls-pods pattern — see docs/CONTROL.md).
    `monitor` runs the fleet health monitor (Agent SRE): off-Opus daemon that detects when an agent is
    off, troubleshoots to a root cause, and per MONITOR_MODE alerts/suggests/auto-fixes (see docs/MONITOR.md)."""
    if args and args[0] == "watch":
        script = REPO / "platform" / "agentd" / "spawn_watcher.py"
        if not script.exists():
            sys.exit("spawn_watcher.py not found in this build.")
        sys.exit(subprocess.run([sys.executable, str(script), *args[1:]]).returncode)
    if args and args[0] == "control-watch":
        script = REPO / "platform" / "agentd" / "control_watcher.py"
        if not script.exists():
            sys.exit("control_watcher.py not found in this build.")
        sys.exit(subprocess.run([sys.executable, str(script), *args[1:]]).returncode)
    if args and args[0] == "monitor":
        script = REPO / "platform" / "agentd" / "fleet_monitor.py"
        if not script.exists():
            sys.exit("fleet_monitor.py not found in this build.")
        sys.exit(subprocess.run([sys.executable, str(script), *args[1:]]).returncode)
    script = REPO / "platform" / "agentd" / "fleet.py"
    if not script.exists():
        sys.exit("fleet.py not found in this build.")
    subprocess.run([sys.executable, str(script), *(args or ["list"])])


def cmd_brain(args):
    """Switch this deployment's brain IN PLACE (memory/inbox/work untouched), then recreate the container.

    Usage: enclave brain <claude|api|local|optimize> [--model M] [--reconfigure] [--yes]
                          [--no-build] [--no-restart]
      --reconfigure  (optimize) re-run the pool wizard even if home/policy.json already exists
      --no-build     recreate the container WITHOUT rebuilding (use when the image already has the mode)
      --no-restart   write the config only; apply later with `enclave run`
    """
    home = DEPLOY / "home"; secrets = DEPLOY / "secrets"; envf = DEPLOY / ".env"
    agent_env = home / "agent.env"
    if not agent_env.exists():
        sys.exit("./home not configured — run 'enclave init' first.")
    yes = _has(args, "--yes")
    pos = [a for a in args if not a.startswith("-")]
    brain = pos[0] if pos else _ask("Brain", default=_read_env("BRAIN", "claude"),
                                     choices=list(BRAINS), yes=yes)
    if brain not in BRAINS:
        sys.exit(f"Unknown brain '{brain}'. Choose: {', '.join(BRAINS)}")
    bspec = BRAINS[brain]
    model = _flag(args, "--model") or bspec["model"]
    if brain in ("claude", "optimize"):
        _check_claude_model(model, _has(args, "--allow-unknown-model"))

    upd_agent = {"BRAIN": brain}
    upd_env = {"BRAIN": brain}
    if brain == "claude":
        upd_agent["MODEL"] = model; upd_env["MODEL"] = model
    elif brain == "optimize":
        top = model if model.startswith("claude") else "claude-opus-4-8"
        upd_agent["MODEL"] = top; upd_agent["MODEL_ROUTINE"] = "claude-sonnet-4-6"; upd_env["MODEL"] = top
        polf = home / "policy.json"
        if not polf.exists() or _has(args, "--reconfigure"):
            pol, sec = _optimize_pool_wizard(yes)
            _write(polf, json.dumps(pol, indent=2) + "\n")
            secrets.mkdir(mode=0o700, parents=True, exist_ok=True)
            for fn, body in sec.items():
                sp = secrets / fn
                if not sp.exists():
                    _write(sp, body, mode=0o600)
        else:
            print(f"  (kept existing pools in {polf} — edit it, or pass --reconfigure)")
    else:  # api / local
        upd_agent["BRAIN_MODEL"] = model; upd_env["MODEL"] = model
        if brain == "local":
            upd_agent["BRAIN_API_BASE"] = "http://host.docker.internal:11434/v1"

    # drop brain-specific keys that don't apply to the new mode (keep the ones we just set)
    stale = {"MODEL", "MODEL_ROUTINE", "BRAIN_MODEL", "BRAIN_API_BASE"} - set(upd_agent)
    _set_env_kv(agent_env, upd_agent, remove=stale)
    _set_env_kv(envf, upd_env)
    print(f"✓ brain → {brain} (model={upd_agent.get('MODEL') or upd_agent.get('BRAIN_MODEL')})")

    if brain in ("claude", "optimize") and not _secret_set(secrets / "anthropic.env", "CLAUDE_CODE_OAUTH_TOKEN"):
        print("  ⚠ Claude token not set — add CLAUDE_CODE_OAUTH_TOKEN to secrets/anthropic.env")
    if brain == "api" and not _secret_set(secrets / "openrouter.env", "OPENROUTER_API_KEY"):
        print("  ⚠ OPENROUTER_API_KEY not set in secrets/openrouter.env")

    if _has(args, "--no-restart"):
        print("  config written — apply with `enclave run` (add --no-build if the image already has this mode)")
        return
    build = not _has(args, "--no-build")
    print(f"Recreating the container to apply brain={brain}" + (" (rebuilding image)…" if build else "…"))
    r = subprocess.run(["docker", "compose", "up", "-d"] + (["--build"] if build else []), cwd=DEPLOY)
    if r.returncode == 0:
        print("✓ applied.")


COMMANDS = {
    "new": cmd_new, "init": cmd_init, "run": cmd_run, "app": cmd_app, "stop": cmd_stop, "logs": cmd_logs,
    "send": cmd_send, "status": cmd_status, "chat": cmd_chat, "publish": cmd_publish, "brain": cmd_brain,
    "snapshot": cmd_snapshot, "vault-encrypt": cmd_vault_encrypt, "vault-decrypt": cmd_vault_decrypt,
    "fleet": cmd_fleet, "console": cmd_console, "update": cmd_update,
}

def main():
    args = sys.argv[1:]
    if not args or args[0] in ("-h", "--help"):
        print(__doc__); sys.exit(0)
    cmd = args[0]
    if cmd not in COMMANDS:
        sys.exit(f"Unknown command '{cmd}'. Available: {', '.join(COMMANDS)}")
    rest = args[1:]
    # `--dir <path>` operates on a deployment OUTSIDE this checkout (lifecycle + init). `new` owns its
    # own --dir (the target folder to scaffold), so it's excluded here and handles DEPLOY itself.
    # We resolve DEPLOY then STRIP --dir + its value so downstream positional parsing (e.g. send's
    # message) never sees them.
    if cmd != "new" and "--dir" in rest:
        global DEPLOY
        i = rest.index("--dir")
        DEPLOY = pathlib.Path(rest[i + 1]).expanduser().resolve() if i + 1 < len(rest) else DEPLOY
        del rest[i:i + 2]
    COMMANDS[cmd](rest)

if __name__ == "__main__":
    main()
