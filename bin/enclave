#!/usr/bin/env python3
"""
enclave — CLI for the Enclave agent runtime.

Commands:
  enclave init                     Interactive wizard: configure this deployment (home/, secrets/, .env)
  enclave run                      Build + start the agent, then open the chat in your browser
  enclave send <msg>               Send a message to the agent's inbox
  enclave logs                     Tail the agent's runner log
  enclave status                   Show agent health and recent activity
  enclave stop                     Stop the agent containers
  enclave chat                     Interactive terminal chat (reads the reply file)
  enclave publish --registry R     Maintainer: build + push images to a registry (teammates `run --pull`)

The wizard + run/stop/etc. all operate on the Enclave repo this script lives in
(the clone IS the deployment, like a configured ps-ops checkout). `init` populates
./home (the agent's mounted /agent), ./secrets (read-only creds), and ./.env.

Flags for non-interactive init (CI / scripted):
  --name N --brain claude|api|local --model M --template T
  --port 8888 --token TOK --bind 127.0.0.1:8888 --yes --force
Flags for run:
  --no-open   don't auto-open the browser
  --no-build  skip the image build (use existing local images)
  --pull      pull prebuilt images from the registry instead of building (see ENCLAVE_*_IMAGE in .env)
"""
import sys, os, re, json, time, pathlib, subprocess, shutil, getpass, urllib.request

HERE = pathlib.Path(__file__).resolve().parent
REPO = HERE.parent  # bin/ -> repo root

# Brain presets: default model + the secret file/key the runtime reads from ./secrets/.
BRAINS = {
    "claude": {"model": "claude-sonnet-4-6", "secret_file": "anthropic.env",
               "secret_key": "CLAUDE_CODE_OAUTH_TOKEN",
               "cred_prompt": "Claude Code OAuth token (from `claude setup-token`)"},
    "api":    {"model": "deepseek/deepseek-chat", "secret_file": "openrouter.env",
               "secret_key": "OPENROUTER_API_KEY",
               "cred_prompt": "OpenRouter API key (sk-or-...)"},
    "local":  {"model": "qwen2.5:7b", "secret_file": None, "secret_key": None,
               "cred_prompt": None},
}


# ── small interactive helpers ────────────────────────────────────────────────
def _interactive():
    return sys.stdin.isatty() and sys.stdout.isatty()

def _ask(label, default=None, choices=None, yes=False):
    if choices:
        label = f"{label} [{'/'.join(choices)}]"
    if default is not None:
        label = f"{label} ({default})"
    if yes or not _interactive():
        return default
    while True:
        try:
            ans = input(f"  {label}: ").strip()
        except (EOFError, KeyboardInterrupt):
            print("\nAborted."); sys.exit(1)
        if not ans:
            return default
        if choices and ans not in choices:
            print(f"    please choose one of: {', '.join(choices)}"); continue
        return ans

def _ask_secret(label, yes=False):
    if yes or not _interactive():
        return ""
    try:
        return getpass.getpass(f"  {label}\n  (paste, or press Enter to skip and add it later): ").strip()
    except (EOFError, KeyboardInterrupt):
        print(); return ""

def _flag(args, name, default=None):
    if name in args:
        i = args.index(name)
        if i + 1 < len(args):
            return args[i + 1]
    return default

def _has(args, name):
    return name in args


# ── init wizard ──────────────────────────────────────────────────────────────
def _templates():
    tdir = REPO / "templates"
    return sorted(p.name for p in tdir.iterdir() if p.is_dir()) if tdir.exists() else []

def _write(path, text, mode=None):
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(text)
    if mode is not None:
        os.chmod(path, mode)

# Deterministic identity so vault commits never prompt or depend on global git config.
_GIT_ENV = {"GIT_AUTHOR_NAME": "enclave", "GIT_AUTHOR_EMAIL": "enclave@local",
            "GIT_COMMITTER_NAME": "enclave", "GIT_COMMITTER_EMAIL": "enclave@local"}

# Credential GATE (fail-closed). Free-form agent memory CAN contain a token/password (pasted into a
# lesson, landed in inbox.md). git history is forever, so a snapshot is BLOCKED if any tracked file
# matches a high-confidence credential pattern. High-confidence only → legitimate prose ("rotate the
# password") doesn't trip it; an actual `password = <secret>` or a real key format does.
_SECRET_RE = [re.compile(p) for p in (
    r"ghp_[A-Za-z0-9]{30,}", r"github_pat_[A-Za-z0-9_]{30,}",
    r"sk-ant-[A-Za-z0-9_-]{20,}", r"sk-or-v1-[A-Za-z0-9]{20,}", r"sk-[A-Za-z0-9]{32,}",
    r"AKIA[0-9A-Z]{16}", r"-----BEGIN [A-Z ]*PRIVATE KEY-----",
    r"xox[baprs]-[A-Za-z0-9-]{10,}", r"AIza[0-9A-Za-z_-]{35}", r"glpat-[A-Za-z0-9_-]{20,}",
    r"(?i)\b(password|passwd|secret|api[_-]?key|access[_-]?token|client[_-]?secret|bearer)\b"
    r"\s*[:=]\s*['\"]?[A-Za-z0-9_\-./+=]{12,}",
)]

def _scan_secrets(home):
    """Return [(file, snippet)] for any STAGED vault file matching a credential pattern. The gate."""
    r = subprocess.run(["git", "diff", "--cached", "--name-only", "-z"], cwd=home,
                       capture_output=True, text=True)
    hits = []
    for rel in (r.stdout.split("\0") if r.stdout else []):
        if not rel:
            continue
        try:
            text = (home / rel).read_text(errors="ignore")
        except OSError:
            continue
        for pat in _SECRET_RE:
            m = pat.search(text)
            if m:
                hits.append((rel, m.group(0)[:24] + "…"))
                break
    return hits

def _vault_commit(home, msg):
    """Stage + SCAN + commit the vault. Returns ('ok'|'nochange'|None, hits). On a credential hit
    returns ('blocked', hits) and does NOT commit (fail-closed)."""
    if shutil.which("git") is None:
        return None, []
    subprocess.run(["git", "add", "-A"], cwd=home, capture_output=True)
    hits = _scan_secrets(home)
    if hits:
        subprocess.run(["git", "reset", "-q"], cwd=home, capture_output=True)  # unstage; never commit a secret
        return "blocked", hits
    r = subprocess.run(["git", "commit", "-q", "-m", msg], cwd=home,
                       env={**os.environ, **_GIT_ENV}, capture_output=True)
    return ("ok" if r.returncode == 0 else "nochange"), []

# Pre-commit hook installed into the vault repo so even a MANUAL `git commit` is scan-gated, not just
# `enclave snapshot`. Self-contained (no enclave dependency) — greps staged files for the same families.
_VAULT_PRECOMMIT = r'''#!/usr/bin/env bash
# Enclave vault guard — block any commit containing a credential (memory leaks are forever).
set -euo pipefail
pat='ghp_[A-Za-z0-9]{30,}|github_pat_[A-Za-z0-9_]{30,}|sk-ant-[A-Za-z0-9_-]{20,}|sk-or-v1-[A-Za-z0-9]{20,}|AKIA[0-9A-Z]{16}|-----BEGIN [A-Z ]*PRIVATE KEY-----|xox[baprs]-[A-Za-z0-9-]{10,}|AIza[0-9A-Za-z_-]{35}|glpat-[A-Za-z0-9_-]{20,}'
bad=0
while IFS= read -r f; do
  [ -f "$f" ] || continue
  if grep -EnI "$pat" "$f" >/dev/null 2>&1; then echo "BLOCKED: credential pattern in $f" >&2; bad=1; fi
done < <(git diff --cached --name-only)
[ "$bad" -eq 0 ] || { echo "Vault commit blocked — redact the secret (use secrets/, not memory)." >&2; exit 1; }
'''

def _init_vault_git(home):
    """Make the deployment's vault version-controlled so memory survives a machine wipe — SAFELY.
    home/ becomes its OWN git repo (independent of the product repo, which gitignores home/). The
    home/.gitignore NEVER tracks secrets/ or transient runtime, and a fail-closed pre-commit hook +
    the snapshot scanner block any credential that leaks into tracked memory. Idempotent; no-op
    without git."""
    gi = home / ".gitignore"
    if not gi.exists():
        _write(gi,
            "# Enclave deployment vault — durable memory is TRACKED; secrets + runtime state are NOT.\n"
            "secrets/\n"        # NEVER commit credentials (the structured cred store)
            "state/\n"          # transient per-tick runtime state
            "logs/\n"
            "uploads/\n"
            "*.log\n"
            ".DS_Store\n")
    if shutil.which("git") is None:
        return None
    if (home / ".git").exists():
        return "exists"
    try:
        subprocess.run(["git", "init", "-q"], cwd=home, check=True, capture_output=True)
        hook = home / ".git" / "hooks" / "pre-commit"
        _write(hook, _VAULT_PRECOMMIT, mode=0o755)
        _vault_commit(home, "init vault (durable memory: knowledge + memory + skills)")
        return "created"
    except Exception:
        return None

def cmd_snapshot(args):
    """Durably save memory (survives a machine wipe) — SCAN-GATED. The AGENT can't git (guard-blocked);
    the runtime/operator snapshots. Fail-closed: a credential in tracked memory BLOCKS the commit.
    Safe to call every tick (no-op when nothing changed). Usage: enclave snapshot ["message"]"""
    home = REPO / "home"
    if not home.exists():
        sys.exit("no home/ — run `enclave init` first")
    if not (home / ".git").exists():
        _init_vault_git(home)
    msg = " ".join(a for a in args if not a.startswith("--")) or \
        f"snapshot {time.strftime('%Y-%m-%dT%H:%MZ', time.gmtime())}"
    r, hits = _vault_commit(home, msg)
    if r == "blocked":
        print("⛔ NOT snapshotted — credential pattern in tracked memory (git history is forever):")
        for f, snip in hits:
            print(f"     {f}: {snip}")
        print("   Move the secret to secrets/ (gitignored) and redact it from memory, then re-run.")
        sys.exit(1)
    print("✓ vault snapshotted" if r == "ok" else
          "(nothing changed — vault already current)" if r == "nochange" else
          "git not available — vault not snapshotted")

def cmd_init(args):
    yes = _has(args, "--yes")
    force = _has(args, "--force")
    home = REPO / "home"
    secrets = REPO / "secrets"
    envf = REPO / ".env"

    populated = home.exists() and any(p.name != ".gitkeep" for p in home.iterdir())
    if populated and not force:
        sys.exit(f"./home is already populated ({home}). Re-run with --force to overwrite, "
                 f"or edit it directly. (secrets/ and .env are left untouched.)")

    print("\nEnclave setup — configure this deployment.\n")

    templates = _templates()
    tpl = _flag(args, "--template") or _ask("Template", default=("ops" if "ops" in templates else (templates[0] if templates else "ops")), choices=(templates or None), yes=yes)
    name = _flag(args, "--name") or _ask("Agent name", default="enclave-agent", yes=yes)
    brain = _flag(args, "--brain") or _ask("Brain", default="claude", choices=list(BRAINS), yes=yes)
    if brain not in BRAINS:
        sys.exit(f"Unknown brain '{brain}'. Choose: {', '.join(BRAINS)}")
    bspec = BRAINS[brain]
    model = _flag(args, "--model") or _ask("Model", default=bspec["model"], yes=yes)
    bind = _flag(args, "--bind") or _ask("Web chat bind (host:port)", default="127.0.0.1:8888", yes=yes)
    port = _flag(args, "--port") or (bind.split(":")[-1] if ":" in bind else "8888")
    token = _flag(args, "--token", "")  # web UI ?token= gate (optional)

    # credential (paste now or later)
    cred = ""
    if bspec["secret_key"]:
        cred = _flag(args, "--cred") or _ask_secret(bspec["cred_prompt"], yes=yes)
        # Guided token for the Claude brain: a teammate may not have a token yet — offer to mint one.
        if not cred and not yes and _interactive() and brain == "claude":
            if shutil.which("claude"):
                if _ask("No token entered. Run `claude setup-token` now to generate one?",
                        default="y", choices=["y", "n"], yes=yes) == "y":
                    print("  Launching `claude setup-token` — complete the browser login; it prints a token.\n")
                    subprocess.run(["claude", "setup-token"])
                    cred = _ask_secret("Paste the token it just printed")
            else:
                print("  (the `claude` CLI isn't on PATH — install it, run `claude setup-token`, then paste the token)")

    tdir = REPO / "templates" / tpl
    if not tdir.exists():
        sys.exit(f"Template '{tpl}' not found in {REPO/'templates'} (have: {', '.join(templates) or 'none'})")

    # 1) home/ from the template (CLAUDE.md, tick.txt, .mcp.json, .claude/settings.json)
    if home.exists() and force:
        # preserve runtime state if any; only replace the definition files
        pass
    home.mkdir(parents=True, exist_ok=True)
    for rel in ["CLAUDE.md", "tick.txt", ".mcp.json"]:
        src = tdir / rel
        if src.exists():
            _write(home / rel, src.read_text().replace("{AGENT_NAME}", name))
    csrc = tdir / ".claude"
    if csrc.exists():
        shutil.copytree(csrc, home / ".claude", dirs_exist_ok=True)

    # 2) agent.env (runtime defaults; NO inline comments after values — loader keeps everything after '=')
    lines = [
        "# Agent runtime config. NO inline comments after values.",
        f"AGENT_ID={name}",
        f"BRAIN={brain}",
    ]
    if brain == "claude":
        lines.append(f"MODEL={model}")
    else:
        lines.append(f"BRAIN_MODEL={model}")
        if brain == "local":
            lines.append("BRAIN_API_BASE=http://host.docker.internal:11434/v1")
    lines += ["RUNTIME_MODE=daemon", "INTERVAL_SECONDS=86400", "PERMISSION=dangerous", "TOOLS_ROOT=/workspace"]
    # Carry any extra knobs the template ships in its agent.env (e.g. GUARD_CLOUD_READONLY=1 for analyst)
    # that the wizard didn't already set — so a template can declare its own profile.
    already = {ln.split("=", 1)[0] for ln in lines if "=" in ln}
    tenv = tdir / "agent.env"
    if tenv.exists():
        for ln in tenv.read_text().splitlines():
            ln = ln.strip()
            if ln and not ln.startswith("#") and "=" in ln and ln.split("=", 1)[0] not in already:
                lines.append(ln)
    _write(home / "agent.env", "\n".join(lines) + "\n")

    # 3) runtime I/O files
    _write(home / "inbox.md", f"# inbox — initialized {time.strftime('%Y-%m-%d')}\n\n")
    _write(home / "work.json", "[]\n")          # BARE list — memory.py requires it (not {"items":[]})
    _write(home / "state" / "rollup.md", f"# {name} status\n\n(no ticks yet)\n")
    (home / "logs").mkdir(parents=True, exist_ok=True)

    # 4) knowledge wiki = the portable default memory (no DB/GPU/service)
    wiki = REPO / "platform" / "agentd" / "wiki.py"
    if wiki.exists():
        r = subprocess.run([sys.executable, str(wiki), "init", "knowledge"], cwd=home)
        if r.returncode != 0:
            print("  (wiki init returned nonzero — continuing; you can run it later)")

    # 5) secrets/ (read-only creds, written 600 inside a 700 dir)
    secrets.mkdir(mode=0o700, parents=True, exist_ok=True)
    try:
        os.chmod(secrets, 0o700)
    except OSError:
        pass
    if bspec["secret_file"]:
        sfile = secrets / bspec["secret_file"]
        if cred:
            _write(sfile, f"{bspec['secret_key']}={cred}\n", mode=0o600)
        elif not sfile.exists():
            _write(sfile, f"# add your credential here, no quotes:\n{bspec['secret_key']}=\n", mode=0o600)
    # ensure anthropic.env exists so compose's env_file never errors (it's required:false anyway)
    apath = secrets / "anthropic.env"
    if not apath.exists():
        _write(apath, "# Claude Code OAuth token (BRAIN=claude). Leave blank for other brains.\nCLAUDE_CODE_OAUTH_TOKEN=\n", mode=0o600)

    # 6) .env (compose-level interpolation: AGENT_ID/BRAIN/MODEL/.../WEB_CHAT_*)
    env_lines = [
        f"AGENT_ID={name}",
        f"BRAIN={brain}",
        f"MODEL={model}",
        "RUNTIME_MODE=daemon",
        "INTERVAL_SECONDS=86400",
        "PERMISSION=dangerous",
        f"WEB_CHAT_BIND={bind}",
        f"WEB_CHAT_TOKEN={token}",
    ]
    _write(envf, "\n".join(env_lines) + "\n")

    # 7) make the vault durable BY DEFAULT — its own scan-gated git repo (secrets/ excluded, a
    # fail-closed pre-commit hook blocks any credential). So memory survives a machine wipe safely.
    vault = _init_vault_git(home)

    print(f"\n✓ Configured agent '{name}' (brain={brain}, model={model}, template={tpl}).")
    if vault == "created":
        print(f"  vault    → home/ is a git repo (memory saved on `enclave snapshot`; secrets/ excluded + scan-gated)")
    print(f"  home/    → mounts to /agent (CLAUDE.md, agent.env, work.json, knowledge/ wiki)")
    needs_cred = bool(bspec["secret_key"])
    cred_present = bool(cred)
    if needs_cred and not cred_present:  # maybe it's already in the file from a prior setup
        sfile = secrets / bspec["secret_file"]
        if sfile.exists():
            for ln in sfile.read_text().splitlines():
                if ln.startswith(bspec["secret_key"] + "=") and ln.split("=", 1)[1].strip():
                    cred_present = True; break
    print(f"  secrets/ → read-only creds" + ("  ⚠ credential not set yet" if (needs_cred and not cred_present) else ""))
    print(f"  .env     → compose config (chat on http://{bind}/)")
    if needs_cred and not cred_present:
        print(f"\n  ⚠ Add your credential before running:")
        print(f"      echo '{bspec['secret_key']}=<your-key>' > secrets/{bspec['secret_file']} && chmod 600 secrets/{bspec['secret_file']}")
    # offer to run
    if _interactive() and not yes:
        if _ask("Start the agent now?", default="y", choices=["y", "n"]) == "y":
            return cmd_run([])
    print("\nNext: enclave run   (build + start + open the browser)")


# ── run / lifecycle ──────────────────────────────────────────────────────────
def _read_env(key, default=None):
    envf = REPO / ".env"
    if envf.exists():
        for line in envf.read_text().splitlines():
            line = line.strip()
            if line and not line.startswith("#") and line.split("=", 1)[0] == key:
                return line.split("=", 1)[1]
    return default

def _open_browser(url):
    import webbrowser
    try:
        if webbrowser.open(url):
            return True
    except Exception:
        pass
    for cmd in (["open", url], ["xdg-open", url], ["cmd", "/c", "start", "", url]):
        try:
            if subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode == 0:
                return True
        except FileNotFoundError:
            continue
    return False

def _wait_reachable(url, timeout=40):
    deadline = time.time() + timeout
    while time.time() < deadline:
        try:
            with urllib.request.urlopen(url, timeout=2) as r:
                if r.status < 500:
                    return True
        except Exception:
            time.sleep(1)
    return False

def cmd_run(args):
    if not (REPO / "docker-compose.yml").exists():
        sys.exit("No docker-compose.yml in the repo — is this an Enclave checkout?")
    home = REPO / "home"
    if not home.exists() or not any(p.name != ".gitkeep" for p in home.iterdir()):
        sys.exit("./home is not configured — run 'enclave init' first.")

    # --pull: fetch prebuilt images from the registry (set ENCLAVE_AGENT_IMAGE/ENCLAVE_CHAT_IMAGE in .env)
    # instead of a local build. Otherwise build locally unless --no-build.
    if _has(args, "--pull"):
        print("Pulling prebuilt images…")
        subprocess.run(["docker", "compose", "pull"], cwd=REPO)
        build = False
    else:
        build = not _has(args, "--no-build")
    cmd = ["docker", "compose", "up", "-d"] + (["--build"] if build else [])
    print("Starting Enclave (docker compose up)…")
    r = subprocess.run(cmd, cwd=REPO)
    if r.returncode != 0:
        sys.exit(r.returncode)

    bind = _read_env("WEB_CHAT_BIND", "127.0.0.1:8888")
    host, _, port = bind.partition(":")
    host = host or "127.0.0.1"
    port = port or "8888"
    token = _read_env("WEB_CHAT_TOKEN", "")
    url = f"http://{host}:{port}/" + (f"?token={token}" if token else "")

    if _has(args, "--no-open"):
        print(f"\nAgent running. Chat: {url}")
        return

    print(f"\nWaiting for the chat UI at http://{host}:{port}/ …")
    if _wait_reachable(f"http://{host}:{port}/", timeout=40):
        if _open_browser(url):
            print(f"Opened {url} in your browser.")
        else:
            print(f"Could not auto-open a browser. Open it manually: {url}")
    else:
        print(f"Chat UI not reachable yet (the agent may still be building). Try: {url}")
        print("  enclave logs   # to watch startup")

def cmd_stop(args):
    subprocess.run(["docker", "compose", "down"], cwd=REPO)

def cmd_publish(args):
    """Maintainer: build + push the agent/chat images to a registry so teammates can `run --pull`."""
    reg = _flag(args, "--registry") or _read_env("ENCLAVE_REGISTRY") or os.environ.get("ENCLAVE_REGISTRY")
    if not reg:
        sys.exit("Set a registry: enclave publish --registry ghcr.io/<owner>   "
                 "(login first: docker login ghcr.io)")
    tag = _flag(args, "--tag", "latest")
    targets = [("Dockerfile.agent", f"{reg}/enclave-agent:{tag}"),
               ("Dockerfile.chat", f"{reg}/enclave-chat:{tag}")]
    for dockerfile, ref in targets:
        print(f"\n=== build + push {ref} ===")
        if subprocess.run(["docker", "build", "-f", dockerfile, "-t", ref, "."], cwd=REPO).returncode != 0:
            sys.exit(f"build failed for {ref}")
        if subprocess.run(["docker", "push", ref], cwd=REPO).returncode != 0:
            sys.exit(f"push failed for {ref} — is `docker login {reg.split('/')[0]}` done?")
    print("\nPublished:")
    for _, ref in targets:
        print(f"  {ref}")
    print("\nTeammates: set these in .env, then `enclave run --pull`:")
    print(f"  ENCLAVE_AGENT_IMAGE={targets[0][1]}")
    print(f"  ENCLAVE_CHAT_IMAGE={targets[1][1]}")

def cmd_logs(args):
    log = REPO / "home" / "logs" / "runner.log"
    if log.exists():
        subprocess.run(["tail", "-f", str(log)])
    else:
        subprocess.run(["docker", "compose", "logs", "-f", "agent"], cwd=REPO)

def cmd_send(args):
    if not args:
        sys.exit("Usage: enclave send <message>")
    message = " ".join(a for a in args if not a.startswith("--"))
    inbox = REPO / "home" / "inbox.md"
    ts = time.strftime("%Y-%m-%dT%H:%MZ", time.gmtime())
    inbox.parent.mkdir(parents=True, exist_ok=True)
    with inbox.open("a") as f:
        f.write(f"\n\n---\n**[Operator at {ts}]**\n\n{message}\n\n*Reply by writing to state/chat-reply.md*\n")
    print(f"Delivered to {inbox}")

def cmd_status(args):
    state = REPO / "home" / "state"
    rollup = state / "rollup.md"
    if rollup.exists():
        print("=== Status ===")
        print(rollup.read_text()[-2000:])
    hb = state / ".heartbeat"
    if hb.exists():
        try:
            age = int(time.time()) - int(hb.read_text().strip())
            print(f"\nLast heartbeat: {age}s ago")
        except ValueError:
            pass

def cmd_chat(args):
    data = REPO / "home"
    inbox = data / "inbox.md"
    reply_file = data / "state" / "chat-reply.md"
    print("Terminal chat — type a message, Enter to send. Ctrl-C to exit.\n")
    last = None
    try:
        last = reply_file.stat().st_mtime
    except OSError:
        pass
    while True:
        try:
            msg = input("You: ").strip()
        except (KeyboardInterrupt, EOFError):
            print("\nExiting."); break
        if not msg:
            continue
        ts = time.strftime("%Y-%m-%dT%H:%MZ", time.gmtime())
        inbox.parent.mkdir(parents=True, exist_ok=True)
        with inbox.open("a") as f:
            f.write(f"\n\n---\n**[Operator at {ts}]**\n\n{msg}\n\n*Write your reply to state/chat-reply.md*\n")
        print("(delivered — waiting for reply…)")
        deadline = time.time() + 600
        while time.time() < deadline:
            time.sleep(2)
            try:
                m = reply_file.stat().st_mtime
            except OSError:
                continue
            if m != last:
                content = ""
                try:
                    content = reply_file.read_text().strip()
                except OSError:
                    pass
                if content:
                    last = m
                    print(f"\nAgent: {content}\n")
                    try:
                        reply_file.write_text("")
                    except OSError:
                        pass
                    break
        else:
            print("(no reply yet — the agent may still be working)")


COMMANDS = {
    "init": cmd_init, "run": cmd_run, "stop": cmd_stop, "logs": cmd_logs,
    "send": cmd_send, "status": cmd_status, "chat": cmd_chat, "publish": cmd_publish,
    "snapshot": cmd_snapshot,
}

def main():
    args = sys.argv[1:]
    if not args or args[0] in ("-h", "--help"):
        print(__doc__); sys.exit(0)
    cmd = args[0]
    if cmd not in COMMANDS:
        sys.exit(f"Unknown command '{cmd}'. Available: {', '.join(COMMANDS)}")
    COMMANDS[cmd](args[1:])

if __name__ == "__main__":
    main()
