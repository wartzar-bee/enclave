{
  "_doc": "Declarative egress allowlist for guard.py (P1). Checked on every Bash/WebFetch/BrowserAction call. Reload on each request — no restart needed. Override path via GUARD_EGRESS_POLICY env.",

  "_policy": "MINIMAL BY DEFAULT. This list is only what an agent needs to think and to install its own dependencies: model APIs, package registries, source, and images. Anything task-specific — publishing platforms, mail, search APIs, cloud consoles, proxies — is DELIBERATELY absent, because the product's claim is that an agent can only reach what you explicitly gave it. A default that already reaches everything is not a security boundary, it is a formality. Opt in by copying an entry from policies/examples/ into this file, or point GUARD_EGRESS_POLICY at your own.",

  "allow": [
    {"host": "*.anthropic.com",          "ports": [443],       "comment": "Anthropic API"},
    {"host": "api.anthropic.com",        "ports": [443]},
    {"host": "openrouter.ai",            "ports": [443],       "comment": "OpenRouter inference gateway"},
    {"host": "api.openrouter.ai",        "ports": [443]},
    {"host": "openrouter.com",           "ports": [443]},
    {"host": "*.openai.com",             "ports": [443],       "comment": "OpenAI-compatible APIs"},
    {"host": "api.openai.com",           "ports": [443]},
    {"host": "api.deepseek.com",         "ports": [443],       "comment": "DeepSeek"},
    {"host": "api.together.xyz",         "ports": [443],       "comment": "Together AI"},
    {"host": "api.mistral.ai",           "ports": [443],       "comment": "Mistral"},
    {"host": "api.cohere.ai",            "ports": [443],       "comment": "Cohere"},
    {"host": "generativelanguage.googleapis.com", "ports": [443], "comment": "Google Gemini"},
    {"host": "us-central1-aiplatform.googleapis.com", "ports": [443], "comment": "Vertex AI"},
    {"host": "*.aiplatform.googleapis.com", "ports": [443]},

    {"host": "github.com",               "ports": [443, 22],   "comment": "GitHub"},
    {"host": "api.github.com",           "ports": [443]},
    {"host": "raw.githubusercontent.com","ports": [443]},
    {"host": "objects.githubusercontent.com", "ports": [443]},
    {"host": "codeload.github.com",      "ports": [443]},

    {"host": "pypi.org",                 "ports": [443],       "comment": "Python packages"},
    {"host": "files.pythonhosted.org",   "ports": [443]},
    {"host": "registry.npmjs.org",       "ports": [443],       "comment": "npm"},
    {"host": "archive.ubuntu.com",       "ports": [80, 443],   "comment": "Ubuntu apt"},
    {"host": "security.ubuntu.com",      "ports": [80, 443]},
    {"host": "deb.debian.org",           "ports": [80, 443]},

    {"host": "registry-1.docker.io",     "ports": [443],       "comment": "Docker Hub"},
    {"host": "auth.docker.io",           "ports": [443]},
    {"host": "production.cloudflare.docker.com", "ports": [443]},

    {"host": "*.amazonaws.com",          "ports": [443],       "comment": "S3-style object storage (some model APIs stream from it)"}
  ],

  "binary_deny_by_default": true,
  "_binary_note": "When binary_deny_by_default is true, any host NOT explicitly in binary_allow gets binary=denied in ENFORCE mode. Report-only in default mode. Set binary_allow entries per-host to permit binary uploads to known-safe destinations.",
  "binary_allow": [
    {"host": "raw.githubusercontent.com",   "comment": "Downloading binaries from GH"},
    {"host": "files.pythonhosted.org",      "comment": "Python wheel downloads"},
    {"host": "objects.githubusercontent.com"},
    {"host": "registry-1.docker.io"},
    {"host": "*.amazonaws.com",             "comment": "S3-style binary object storage"}
  ]
}
