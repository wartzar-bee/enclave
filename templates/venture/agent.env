# Agent runtime config. NO inline comments after values (the loader keeps everything after '=').
# Venture agent: a solo, continuously SELF-DRIVING operator graduated to run one venture toward a KPI.
# Each tick it reconstructs state from memory + work.json and takes the next best step — no human in the
# loop. INTERVAL_SECONDS is its heartbeat; RUNTIME_MODE=daemon keeps it running. SUPERVISE=auto turns on
# the in-container OFF-OPUS supervisor iff BRAIN=local (cheap planner + verify gate); with BRAIN=claude
# the model plans its own queue each tick.
AGENT_ID=venture-agent
BRAIN=claude
MODEL=claude-sonnet-4-6
RUNTIME_MODE=daemon
INTERVAL_SECONDS=10800
PERMISSION=dangerous
TOOLS_ROOT=/workspace
SUPERVISE=auto
